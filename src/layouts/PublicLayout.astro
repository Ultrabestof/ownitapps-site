---
// src/layouts/PublicLayout.astro
// Public website layout أ¢â‚¬â€‌ header + main content + footer
// Used by: homepage, blog, product pages, pSEO pages, glossary, etc.

import BaseLayout from './BaseLayout.astro';
import PublicHeader from '../components/navigation/PublicHeader.astro';
import Footer from '../components/navigation/Footer.astro';
import type { SEOProps } from '../lib/seo';

interface Props {
  seo: SEOProps;
  schema?: object | object[] | string | null;
  class?: string;
  /** Show breadcrumbs above content */
  breadcrumbs?: Array<{ name: string; href: string }>;
  /** Remove top/bottom padding for full-bleed hero pages */
  fullBleed?: boolean;
}

const { seo, schema, breadcrumbs, fullBleed = false } = Astro.props;
const path = Astro.url.pathname;
---

<BaseLayout {seo} {path} schema={typeof schema === "string" ? null : (schema ?? null)}>
  <div class="flex flex-col min-h-screen">
    <PublicHeader />

    <main id="main-content" class:list={['flex-1', !fullBleed && 'pt-16']} tabindex="-1">
      {breadcrumbs && breadcrumbs.length > 0 && (
        <div class="container">
          <nav aria-label="Breadcrumb" class="breadcrumbs py-4">
            <a href="/">Home</a>
            {breadcrumbs.map((crumb, i) => (
              <>
                <span class="sep" aria-hidden="true">أ¢â‚¬ط›</span>
                {i === breadcrumbs.length - 1
                  ? <span class="current" aria-current="page">{crumb.name}</span>
                  : <a href={crumb.href}>{crumb.name}</a>
                }
              </>
            ))}
          </nav>
        </div>
      )}

      <slot />
    </main>

    <footer />
  <section class="footer-trust-strip" aria-label="OwnitApps trust features">
    <div class="footer-trust-item">
      <img src="/media/icons/offline-first.png" alt="" loading="lazy" />
      <span>Offline-first</span>
    </div>
    <div class="footer-trust-item">
      <img src="/media/icons/private-default.png" alt="" loading="lazy" />
      <span>Private by default</span>
    </div>
    <div class="footer-trust-item">
      <img src="/media/icons/no-subscriptions.png" alt="" loading="lazy" />
      <span>No forced subscriptions</span>
    </div>
    <div class="footer-trust-item">
      <img src="/media/icons/local-data.png" alt="" loading="lazy" />
      <span>Local data ownership</span>
    </div>
    <div class="footer-trust-item">
      <img src="/media/icons/no-account.png" alt="" loading="lazy" />
      <span>No account required</span>
    </div>
    <div class="footer-trust-item">
      <img src="/media/icons/buy-once.png" alt="" loading="lazy" />
      <span>Buy once, use forever</span>
    </div>
  </section>

  </div>
</BaseLayout>




<style is:global>
  /* OwnitApps footer trust strip - forced global fix */
  .footer-trust-strip {
    width: 100% !important;
    padding: 18px 28px !important;
    background: #242424 !important;
    border-top: 1px solid #3A3A3A !important;
    border-bottom: 1px solid #3A3A3A !important;
    display: grid !important;
    grid-template-columns: repeat(6, minmax(0, 1fr)) !important;
    gap: 0 !important;
    align-items: center !important;
    box-sizing: border-box !important;
  }

  .footer-trust-item {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 10px !important;
    min-width: 0 !important;
    padding: 0 14px !important;
    color: #E8DDD0 !important;
    font-size: 13.5px !important;
    font-weight: 600 !important;
    letter-spacing: 0.02em !important;
    line-height: 1.3 !important;
    text-align: left !important;
    box-sizing: border-box !important;
  }

  .footer-trust-item:not(:last-child) {
    border-right: 1px solid rgba(232, 221, 208, 0.16) !important;
  }

  .footer-trust-item img {
    width: 38px !important;
    height: 38px !important;
    max-width: 38px !important;
    max-height: 38px !important;
    object-fit: contain !important;
    flex: 0 0 38px !important;
    display: block !important;
    border-radius: 8px !important;
  }

  .footer-trust-item span {
    display: block !important;
    color: #E8DDD0 !important;
    white-space: normal !important;
  }

  @media (max-width: 1100px) {
    .footer-trust-strip {
      grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
      row-gap: 18px !important;
    }

    .footer-trust-item:nth-child(3),
    .footer-trust-item:nth-child(6) {
      border-right: 0 !important;
    }
  }

  @media (max-width: 640px) {
    .footer-trust-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      padding: 18px 14px !important;
      row-gap: 16px !important;
    }

    .footer-trust-item {
      justify-content: flex-start !important;
      padding: 0 8px !important;
      font-size: 12px !important;
      border-right: 0 !important;
    }

    .footer-trust-item img {
      width: 30px !important;
      height: 30px !important;
      max-width: 30px !important;
      max-height: 30px !important;
      flex-basis: 30px !important;
    }
  }
</style>


