---
// src/layouts/AdminLayout.astro
// Admin dashboard layout — fixed sidebar + main content area
// Architecture: static-first, designed for future backend integration
// noindex enforced — admin routes are never crawlable

import BaseLayout from './BaseLayout.astro';
import { SITE } from '../data/site';

interface Props {
  title: string;
  section?: string;
  class?: string;
}

const { title, section = 'dashboard', class: className } = Astro.props;
const path = Astro.url.pathname;

const seo = {
  title: `${title} — Admin`,
  description: 'OwnitApps admin dashboard',
  noindex: true,
};

const navItems = [
  { href: '/admin', label: 'Dashboard', icon: '⬛', id: 'dashboard' },
  { href: '/admin/posts', label: 'Posts', icon: '📝', id: 'posts' },
  { href: '/admin/products', label: 'Products', icon: '📦', id: 'products' },
  { href: '/admin/pseo', label: 'pSEO Pages', icon: '🔁', id: 'pseo' },
  { href: '/admin/seo', label: 'SEO Audit', icon: '🔍', id: 'seo' },
  { href: '/admin/internal-links', label: 'Internal Links', icon: '🔗', id: 'internal-links' },
  { href: '/admin/categories', label: 'Categories', icon: '🏷️', id: 'categories' },
  { href: '/admin/media', label: 'Media', icon: '🖼️', id: 'media' },
  { href: '/admin/import-export', label: 'Import / Export', icon: '↕️', id: 'import-export' },
  { href: '/admin/settings', label: 'Settings', icon: '⚙️', id: 'settings' },
];

const currentSection = navItems.find(n => n.id === section);
---

<BaseLayout {seo} path={path}>
  <div class="app-shell">

    <!-- Fixed Sidebar -->
    <nav
      class="sidebar flex flex-col"
      aria-label="Admin navigation"
      style="position: fixed; top: 0; left: 0; height: 100vh; width: 220px; z-index: var(--z-sidebar); overflow-y: auto;"
    >
      <!-- Brand -->
      <div class="px-4 py-5 border-b border-sidebar-border flex-shrink-0">
        <a href="/" class="flex items-center gap-2 group">
          <span style="font-family: var(--font-heading); font-weight: 800; font-size: 1.125rem; color: var(--sidebar-text); letter-spacing: -0.03em;">
            OwnIt<span style="color: var(--gold);">Apps</span>
          </span>
        </a>
        <p style="font-family: var(--font-mono); font-size: 0.625rem; color: var(--sidebar-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 2px;">
          Admin Dashboard
        </p>
      </div>

      <!-- Nav Items -->
      <div class="flex-1 py-3 px-2">
        <ul role="list" class="space-y-0.5">
          {navItems.map(item => {
            const isActive = path === item.href || (item.href !== '/admin' && path.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150 group',
                    isActive
                      ? 'bg-gold text-[#1a1208] font-semibold'
                      : 'text-sidebar-muted hover:text-sidebar-text hover:bg-white/5'
                  ]}
                  style="font-family: var(--font-body); font-size: 0.8125rem; min-height: 36px; border-radius: var(--rs);"
                >
                  <span aria-hidden="true" class="text-base leading-none">{item.icon}</span>
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <!-- Footer -->
      <div class="px-4 py-4 border-t border-sidebar-border flex-shrink-0">
        <a
          href="/"
          style="font-family: var(--font-mono); font-size: 0.625rem; color: var(--sidebar-muted); letter-spacing: 0.06em; text-transform: uppercase; display: block; margin-bottom: 4px;"
          class="hover:text-gold transition-colors"
        >
          ← Back to site
        </a>
        <p style="font-family: var(--font-mono); font-size: 0.5625rem; color: var(--sidebar-border); letter-spacing: 0.04em;">
          {SITE.name} v1.0
        </p>
      </div>
    </nav>

    <!-- Main Content Area -->
    <div
      class="main"
      style="margin-left: 220px; min-height: 100vh; background: var(--main-bg);"
    >
      <!-- Top bar -->
      <header
        class="sticky top-0 z-50 border-b flex items-center justify-between px-6 py-3"
        style="background: var(--main-bg); border-color: var(--border-light); height: 56px;"
      >
        <div class="flex items-center gap-3">
          <span style="font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em;">
            {currentSection?.icon} {currentSection?.label ?? 'Admin'}
          </span>
          <span style="color: var(--border-medium);">›</span>
          <h1 style="font-family: var(--font-heading); font-size: 0.9375rem; font-weight: 700; color: var(--text-primary); margin: 0; letter-spacing: -0.01em;">
            {title}
          </h1>
        </div>
        <div class="flex items-center gap-3">
          <a
            href={SITE.url}
            target="_blank"
            rel="noopener"
            class="btn-ghost text-xs px-3 py-1.5"
            style="min-height: 32px; font-size: 0.75rem;"
          >
            View Site ↗
          </a>
        </div>
      </header>

      <!-- Page content -->
      <div class:list={['p-6', className]}>
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>
