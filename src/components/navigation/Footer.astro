---
// src/components/navigation/Footer.astro
// Site-wide footer with nav columns, brand statement, legal links

import { SITE } from '../../data/site';

const year = new Date().getFullYear();
---

<footer role="contentinfo" style="background: var(--sidebar-bg); color: var(--sidebar-text); margin-top: auto;">

  <!-- Top footer grid -->
  <div class="container py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10">

      <!-- Brand Column -->
      <div class="lg:col-span-2">
        <!-- Logo -->
        <a href="/" class="inline-flex items-center gap-2.5 mb-4 group" aria-label={SITE.name}>
          <div
            class="w-9 h-9 flex items-center justify-center rounded flex-shrink-0"
            style="background: var(--gold); border-radius: var(--rs);"
            aria-hidden="true"
          >
            <span style="font-family: var(--font-heading); font-weight: 800; font-size: 1rem; color: #1a1208;">O</span>
          </div>
          <span style="font-family: var(--font-heading); font-weight: 800; font-size: 1.25rem; letter-spacing: -0.03em; color: var(--sidebar-text);">
            OwnIt<span style="color: var(--gold);">Apps</span>
          </span>
        </a>

        <!-- Slogan -->
        <p
          style="font-family: var(--font-mono); font-size: 0.6875rem; color: var(--gold); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 12px;"
        >
          {SITE.slogan}
        </p>

        <!-- Description -->
        <p style="font-size: 0.875rem; color: var(--sidebar-muted); line-height: 1.65; max-width: 300px; margin-bottom: 16px;">
          Practical digital tools designed for people who want to own their data — without subscriptions, cloud lock-in, or forced accounts.
        </p>

        <!-- Official URLs -->
        <div style="font-family: var(--font-mono); font-size: 0.6875rem; color: var(--sidebar-muted);">
          <p>Official: <a href={SITE.url} style="color: var(--sidebar-muted);" class="hover:text-gold transition-colors">ownitapps.com</a></p>
          <p>Updates: <a href={SITE.updateUrl} style="color: var(--sidebar-muted);" class="hover:text-gold transition-colors">ownitapps.com/update</a></p>
        </div>
      </div>

      <!-- Nav Columns -->
      {SITE.footerCols.map(col => (
        <div>
          <h3 style="font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sidebar-muted); margin-bottom: 14px;">
            {col.heading}
          </h3>
          <ul class="space-y-2.5" role="list">
            {col.links.map(link => (
              <li>
                <a
                  href={link.href}
                  style="font-size: 0.875rem; color: var(--sidebar-text); opacity: 0.75; transition: opacity 0.15s, color 0.15s;"
                  class="hover:opacity-100 hover:text-gold"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Glossary Column -->
      <div>
        <h3 style="font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sidebar-muted); margin-bottom: 14px;">
          Glossary
        </h3>
        <ul class="space-y-2.5" role="list">
          {SITE.nav.glossary.map(link => (
            <li>
              <a
                href={link.href}
                style="font-size: 0.875rem; color: var(--sidebar-text); opacity: 0.75; transition: opacity 0.15s, color 0.15s;"
                class="hover:opacity-100 hover:text-gold"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Philosophy strip -->
  <div style="border-top: 1px solid var(--sidebar-border); border-bottom: 1px solid var(--sidebar-border); padding: 16px 0;">
    <div class="container">
      <div class="flex flex-wrap gap-x-6 gap-y-2 items-center justify-center text-center" style="font-family: var(--font-mono); font-size: 0.6875rem; color: var(--sidebar-muted); letter-spacing: 0.06em;">
        <span>📴 Offline-first</span>
        <span style="color: var(--sidebar-border);">·</span>
        <span>🔒 Private by default</span>
        <span style="color: var(--sidebar-border);">·</span>
        <span>⛔ No forced subscriptions</span>
        <span style="color: var(--sidebar-border);">·</span>
        <span>🗄️ Local data ownership</span>
        <span style="color: var(--sidebar-border);">·</span>
        <span>🚫 No account required</span>
        <span style="color: var(--sidebar-border);">·</span>
        <span>🧱 Buy once, use forever</span>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="container py-5">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">

      <!-- Copyright -->
      <p style="font-family: var(--font-mono); font-size: 0.6875rem; color: var(--sidebar-muted); text-align: center;">
        © {year} {SITE.name} · {SITE.slogan} · Official: ownitapps.com · Updates: ownitapps.com/update
      </p>

      <!-- Legal links -->
      <nav aria-label="Legal navigation">
        <ul class="flex flex-wrap items-center gap-4" role="list">
          {SITE.nav.legal.map(link => (
            <li>
              <a
                href={link.href}
                style="font-family: var(--font-mono); font-size: 0.625rem; color: var(--sidebar-muted); letter-spacing: 0.06em; text-transform: uppercase; transition: color 0.15s;"
                class="hover:text-gold"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</footer>
