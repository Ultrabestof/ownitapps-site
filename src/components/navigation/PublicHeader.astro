---
// src/components/navigation/PublicHeader.astro
// Sticky public website header
// Desktop: logo + nav links + CTA button
// Mobile: logo + hamburger menu

import { SITE } from '../../data/site';

const path = Astro.url.pathname;

const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b transition-shadow duration-200"
  style="background: rgba(245, 240, 232, 0.95); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-color: var(--border-light);"
  role="banner"
>
  <div class="container">
    <div class="flex items-center justify-between h-16 gap-6">

      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2 flex-shrink-0 group"
        aria-label={`${SITE.name} — ${SITE.slogan}`}
      >
        <img
          src="/assets/logo/ownitapps-icon.svg"
          alt=""
          class="w-9 h-9 flex-shrink-0"
          style="display:block;"
          aria-hidden="true"
        />
        <span
          class="hidden sm:block"
          style="font-family: var(--font-heading); font-weight: 800; font-size: 1.125rem; color: var(--text-primary); letter-spacing: -0.03em;"
        >
          Ownit<span style="color: var(--gold);">Apps</span>
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav
        class="hidden md:flex items-center gap-1"
        aria-label="Main navigation"
      >
        {SITE.nav.main.map(item => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'px-3.5 py-2 rounded text-sm font-medium transition-colors duration-150',
              isActive(item.href)
                ? 'text-gold bg-gold/10'
                : 'text-secondary hover:text-primary hover:bg-black/5'
            ]}
            style="font-family: var(--font-body); border-radius: var(--rs); font-size: 0.875rem;"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Right Side: CTA + Mobile Menu -->
      <div class="flex items-center gap-3">
        <!-- Start Here CTA (desktop) -->
        <a
          href="/apps"
          class="hidden md:inline-flex btn-gold"
          style="font-size: 0.875rem; padding: 0.5rem 1.125rem; min-height: 40px;"
        >
          Browse Apps
        </a>

        <!-- Mobile Menu Toggle -->
        <button
          id="mobile-menu-btn"
          class="md:hidden flex items-center justify-center w-10 h-10 rounded transition-colors"
          style="border-radius: var(--rs); border: 1.5px solid var(--border-medium);"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Toggle navigation menu"
        >
          <svg id="menu-icon-open" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <rect x="1" y="3" width="16" height="2" rx="1" fill="currentColor"/>
            <rect x="1" y="8" width="16" height="2" rx="1" fill="currentColor"/>
            <rect x="1" y="13" width="16" height="2" rx="1" fill="currentColor"/>
          </svg>
          <svg id="menu-icon-close" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="hidden">
            <path d="M3 3L15 15M15 3L3 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t"
    style="border-color: var(--border-light); background: var(--main-bg);"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="container py-4">
      <ul class="space-y-1" role="list">
        {SITE.nav.main.map(item => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class:list={[
                'flex items-center px-4 py-3 rounded text-base font-medium transition-colors',
                isActive(item.href)
                  ? 'text-gold bg-gold/10'
                  : 'text-primary hover:bg-black/5'
              ]}
              style="border-radius: var(--rs); min-height: 48px;"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-4 pt-4 border-t" style="border-color: var(--border-light);">
        <a href="/apps" class="btn-gold w-full justify-center">
          Browse Apps
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Skip to main content (accessibility) -->
<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[900] focus:px-4 focus:py-2 focus:rounded focus:bg-gold focus:text-[#1a1208] focus:font-bold"
>
  Skip to main content
</a>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (btn && menu && iconOpen && iconClose) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
      iconOpen.classList.toggle('hidden', !isOpen);
      iconClose.classList.toggle('hidden', isOpen);
    });
  }

  // Shadow on scroll
  const header = document.getElementById('site-header');
  if (header) {
    const observer = new IntersectionObserver(
      ([e]) => {
        if (e) header.classList.toggle('shadow-md', e.intersectionRatio < 1);
      },
      { threshold: [1] }
    );
    const sentinel = document.createElement('div');
    sentinel.style.cssText = 'position: absolute; top: 0; left: 0; height: 1px; width: 1px; pointer-events: none;';
    document.body.prepend(sentinel);
    observer.observe(sentinel);
  }
</script>
