---
import PublicLayout from '@layouts/PublicLayout.astro';
import { buildSEO } from '@lib/seo';
import { SITE } from '@data/site';

const seo = buildSEO({
  title: 'HTML Apps That Work Offline',
  description: 'OwnitApps builds browser-based HTML apps designed to run locally and support offline-first personal workflows.',
  canonical: `${SITE.url}${'/html-apps-that-work-offline'}`,
});
---

<PublicLayout seo={seo} schema={null}>
  <section class="container py-16">
    <div class="max-w-3xl">
      <span class="badge badge-gold mb-4">Source of Truth</span>
      <h1 class="mb-4">HTML Apps That Work Offline</h1>
      <p class="text-lg leading-relaxed text-[var(--text-secondary)] mb-8">Offline HTML apps can run in the browser without requiring a cloud account for the core workflow.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-4 mt-8">
      <a href="/glossary/html-apps" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">HTML Apps Glossary</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Learn what HTML apps are.</p>
      </a>
      <a href="/offline-first-apps" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Offline-First Apps</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Learn offline-first design.</p>
      </a>
      <a href="/apps" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Browse Apps</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">See OwnitApps tools.</p>
      </a>
    </div>
  </section>
</PublicLayout>
