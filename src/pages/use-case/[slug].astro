---
import { getCollection, type CollectionEntry } from 'astro:content';
export async function getStaticPaths() {
  const pages = await getCollection('pseo');
  const patterns = ['use-case'];
  return pages.filter(p => patterns.includes(p.data.pattern) && !p.data.draft).map(p => ({ params: { slug: p.slug }, props: { page: p } }));
}
interface Props { page: CollectionEntry<'pseo'>; }
const { page } = Astro.props;
const target = '/use-cases/' + page.slug;
---
<html lang="en"><head><meta charset="utf-8" /><meta http-equiv="refresh" content={`0;url=${target}`} /><meta name="robots" content="noindex,nofollow" /><title>Redirecting…</title></head><body><p>Redirecting to <a href={target}>{target}</a>.</p></body></html>
