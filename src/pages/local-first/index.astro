---
import PublicLayout from '@layouts/PublicLayout.astro';
import { buildSEO } from '@lib/seo';
import { SITE } from '@data/site';

const seo = buildSEO({
  title: 'Local-First Software Hub',
  description: 'Programmatic SEO hub for local-first software, local data ownership, and private browser-based tools.',
  canonical: `${SITE.url}${'/local-first'}`,
});
---

<PublicLayout seo={seo} schema={null}>
  <section class="container py-16">
    <div class="max-w-3xl">
      <span class="badge badge-gold mb-4">pSEO Hub</span>
      <h1 class="mb-4">Local-First Software</h1>
      <p class="text-lg leading-relaxed text-[var(--text-secondary)] mb-8">Pages about tools that treat the user’s device as the primary home for their data.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-4 mt-8">
      <a href="/glossary/local-first-software" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Glossary</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Local-first definition.</p>
      </a>
      <a href="/local-data-tools" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Local Data Tools</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Source page.</p>
      </a>
      <a href="/apps" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Apps</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Browse tools.</p>
      </a>
    </div>
  </section>
</PublicLayout>
