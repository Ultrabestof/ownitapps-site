---
import PublicLayout from '@layouts/PublicLayout.astro';
import { buildSEO } from '@lib/seo';
import { SITE } from '@data/site';

const seo = buildSEO({
  title: 'Offline Tools Hub',
  description: 'Programmatic SEO hub for offline-first digital tools and local-first personal dashboards.',
  canonical: `${SITE.url}${'/offline-tools'}`,
});
---

<PublicLayout seo={seo} schema={null}>
  <section class="container py-16">
    <div class="max-w-3xl">
      <span class="badge badge-gold mb-4">pSEO Hub</span>
      <h1 class="mb-4">Offline Tools</h1>
      <p class="text-lg leading-relaxed text-[var(--text-secondary)] mb-8">Offline tool pages for workflows that should keep working without constant internet access.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-4 mt-8">
      <a href="/offline-tools/offline-debt-tracker" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Debt Tracker</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Offline debt tracker page.</p>
      </a>
      <a href="/offline-first-apps" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Offline-First Apps</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Source page.</p>
      </a>
      <a href="/apps" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Apps</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Browse tools.</p>
      </a>
    </div>
  </section>
</PublicLayout>
