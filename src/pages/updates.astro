---
import PublicLayout from '@layouts/PublicLayout.astro';
import { buildSEO } from '@lib/seo';
import { SITE } from '@data/site';

const seo = buildSEO({
  title: 'OwnitApps Updates',
  description: 'Official OwnitApps updates hub pointing to the primary update page and product changelogs.',
  canonical: `${SITE.url}${'/updates'}`,
});
---

<PublicLayout seo={seo} schema={null}>
  <section class="container py-16">
    <div class="max-w-3xl">
      <span class="badge badge-gold mb-4">Updates</span>
      <h1 class="mb-4">OwnitApps Updates Hub</h1>
      <p class="text-lg leading-relaxed text-[var(--text-secondary)] mb-8">The official updates page is /update. Product-specific changelogs also live inside each app page.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-4 mt-8">
      <a href="/update" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Official Update Page</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Go to the canonical update route.</p>
      </a>
      <a href="/apps" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Apps</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Find app-specific updates.</p>
      </a>
      <a href="/contact" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Contact</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Ask support a question.</p>
      </a>
    </div>
  </section>
</PublicLayout>
