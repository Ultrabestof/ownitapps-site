---
import PublicLayout from '@layouts/PublicLayout.astro';
import { buildSEO } from '@lib/seo';
import { SITE } from '@data/site';

const seo = buildSEO({
  title: 'Terms of Service',
  description: 'Terms of Service for OwnitApps.',
  canonical: `${SITE.url}${'/terms'}`,
});
---

<PublicLayout seo={seo} schema={null}>
  <section class="container py-16">
    <div class="max-w-3xl">
      <span class="badge badge-gold mb-4">Legal</span>
      <h1 class="mb-4">Terms of Service</h1>
      <p class="text-lg leading-relaxed text-[var(--text-secondary)] mb-8">The canonical terms of service lives at /legal/terms. Use the link below to read it.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-4 mt-8">
      <a href="/legal/terms" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Terms of Service</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Open the canonical legal page.</p>
      </a>
    </div>
  </section>
</PublicLayout>
