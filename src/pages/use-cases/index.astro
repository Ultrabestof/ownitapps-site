---
import PublicLayout from '@layouts/PublicLayout.astro';
import { buildSEO } from '@lib/seo';
import { SITE } from '@data/site';

const seo = buildSEO({
  title: 'OwnitApps Use Cases',
  description: 'Use-case hub for offline-first personal organization, finance, home, health, and document workflows.',
  canonical: `${SITE.url}${'/use-cases'}`,
});
---

<PublicLayout seo={seo} schema={null}>
  <section class="container py-16">
    <div class="max-w-3xl">
      <span class="badge badge-gold mb-4">Use Cases</span>
      <h1 class="mb-4">Use Cases</h1>
      <p class="text-lg leading-relaxed text-[var(--text-secondary)] mb-8">Explore practical situations where offline-first, buy-once tools make sense.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-4 mt-8">
      <a href="/use-cases/manage-family-documents-offline" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Home Documents</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Manage family documents offline.</p>
      </a>
      <a href="/resources" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Resources</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Read resource guides.</p>
      </a>
      <a href="/apps" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Apps</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Browse tools.</p>
      </a>
    </div>
  </section>
</PublicLayout>
