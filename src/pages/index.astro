---
// src/pages/index.astro
// OwnitApps Homepage - D1-powered public discovery hub

import PublicLayout from '../layouts/PublicLayout.astro';
import { SITE } from '../data/site';
import {
  organizationSchema,
  websiteSchema,
} from '../lib/schema';

const seo = {
  title: 'OwnitApps - Own Your Tools. Own Your Data.',
  description:
    'Buy-once, offline-first digital tools that work without forced accounts, subscriptions, or cloud lock-in. Your OS. Your Data. Your Rules.',
  canonical: SITE.url,
  image: SITE.defaultOgImage,
  type: 'website' as const,
};

const schema = [organizationSchema(), websiteSchema()];
---

<PublicLayout {seo} {schema} fullBleed>
  <style>
    .oa-page {
      background: var(--main-bg);
      color: var(--text-primary);
    }

    .oa-wrap {
      width: min(1120px, calc(100% - 32px));
      margin: 0 auto;
    }

    .oa-section {
      padding: clamp(56px, 8vw, 96px) 0;
    }

    .oa-section.alt {
      background: var(--surface-2);
    }

    .oa-hero {
      position: relative;
      overflow: hidden;
      padding: clamp(72px, 10vw, 130px) 0 clamp(64px, 9vw, 110px);
      background:
        radial-gradient(circle at 70% 12%, rgba(201,168,76,.14), transparent 38%),
        radial-gradient(circle at 18% 80%, rgba(201,168,76,.08), transparent 34%),
        var(--main-bg);
    }

    .oa-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(320px, .95fr);
      gap: clamp(28px, 6vw, 64px);
      align-items: center;
    }

    .oa-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 18px;
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: #806515;
    }

    .oa-h1 {
      font-family: var(--font-heading);
      font-size: clamp(48px, 9vw, 96px);
      line-height: .92;
      letter-spacing: -.075em;
      margin: 0 0 22px;
      color: var(--text-primary);
    }

    .oa-gold {
      color: var(--gold);
    }

    .oa-lede {
      font-size: clamp(18px, 2.2vw, 23px);
      line-height: 1.55;
      color: var(--text-secondary);
      max-width: 670px;
      margin: 0 0 28px;
    }

    .oa-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 24px;
    }

    .oa-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 11px 16px;
      border-radius: 12px;
      font-weight: 900;
      text-decoration: none;
      border: 1px solid var(--border-light);
      color: var(--text-primary);
      background: #fff;
    }

    .oa-button.gold {
      background: var(--gold);
      border-color: rgba(201,168,76,.5);
      color: #1f1f1f;
    }

    .oa-trust-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 8px;
    }

    .oa-pill {
      display: inline-flex;
      align-items: center;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,.75);
      border: 1px solid var(--border-light);
      color: var(--text-muted);
      font-family: var(--font-mono);
      font-size: 11px;
      line-height: 1.1;
    }

    .oa-hero-panel {
      background: rgba(255,255,255,.76);
      border: 1px solid var(--border-light);
      border-radius: 28px;
      padding: 24px;
      box-shadow: 0 28px 90px rgba(43,43,43,.08);
      backdrop-filter: blur(10px);
    }

    .oa-panel-title {
      font-family: var(--font-heading);
      font-size: 24px;
      letter-spacing: -.035em;
      margin: 0 0 16px;
    }

    .oa-stat-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 16px;
    }

    .oa-stat {
      background: var(--surface-2);
      border: 1px solid var(--border-light);
      border-radius: 18px;
      padding: 16px;
    }

    .oa-stat strong {
      display: block;
      font-family: var(--font-heading);
      font-size: 32px;
      line-height: 1;
      letter-spacing: -.04em;
      margin-bottom: 6px;
    }

    .oa-stat span {
      color: var(--text-muted);
      font-size: 12px;
      font-family: var(--font-mono);
    }

    .oa-mini-list {
      display: grid;
      gap: 10px;
    }

    .oa-mini-item {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      padding: 12px;
      border-radius: 16px;
      background: #fff;
      border: 1px solid var(--border-light);
      font-size: 13px;
    }

    .oa-strip {
      background: var(--sidebar-bg);
      border-top: 1px solid var(--sidebar-border);
      border-bottom: 1px solid var(--sidebar-border);
      padding: 18px 0;
    }

    .oa-strip-inner {
      display: flex;
      justify-content: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .oa-strip .oa-pill {
      background: rgba(255,255,255,.05);
      border-color: var(--sidebar-border);
      color: var(--sidebar-text);
    }

    .oa-section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 28px;
    }

    .oa-section-title {
      font-family: var(--font-heading);
      font-size: clamp(34px, 5vw, 56px);
      line-height: 1;
      letter-spacing: -.06em;
      margin: 0 0 12px;
    }

    .oa-section-copy {
      color: var(--text-secondary);
      font-size: 17px;
      line-height: 1.65;
      max-width: 680px;
      margin: 0;
    }

    .oa-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 18px;
    }

    .oa-card {
      display: flex;
      flex-direction: column;
      min-height: 100%;
      background: #fff;
      border: 1px solid var(--border-light);
      border-radius: 22px;
      overflow: hidden;
      color: inherit;
      text-decoration: none;
      box-shadow: 0 18px 54px rgba(43,43,43,.055);
      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

    .oa-card:hover {
      transform: translateY(-3px);
      border-color: rgba(201,168,76,.45);
      box-shadow: 0 28px 70px rgba(43,43,43,.09);
    }

    .oa-card-img {
      width: 100%;
      height: 190px;
      object-fit: cover;
      background: var(--surface-2);
      border-bottom: 1px solid var(--border-light);
    }

    .oa-card-body {
      padding: 20px;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .oa-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-bottom: 12px;
    }

    .oa-badge {
      display: inline-flex;
      align-items: center;
      padding: 5px 9px;
      border-radius: 999px;
      background: rgba(201,168,76,.12);
      border: 1px solid rgba(201,168,76,.2);
      color: #806515;
      font-family: var(--font-mono);
      font-size: 11px;
      line-height: 1;
    }

    .oa-card h3 {
      font-family: var(--font-heading);
      font-size: 22px;
      line-height: 1.12;
      letter-spacing: -.035em;
      margin: 0 0 9px;
    }

    .oa-card p {
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0 0 18px;
      font-size: 14px;
      flex: 1;
    }

    .oa-card-foot {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      color: var(--text-muted);
      font-family: var(--font-mono);
      font-size: 12px;
      border-top: 1px solid var(--border-light);
      padding-top: 14px;
      margin-top: auto;
    }

    .oa-problem-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 14px;
    }

    .oa-problem {
      background: #fff;
      border: 1px solid var(--border-light);
      border-radius: 20px;
      padding: 20px;
    }

    .oa-problem strong {
      display: block;
      font-family: var(--font-heading);
      font-size: 18px;
      letter-spacing: -.025em;
      margin-bottom: 8px;
    }

    .oa-problem p {
      color: var(--text-secondary);
      font-size: 14px;
      line-height: 1.6;
      margin: 0;
    }

    .oa-answer {
      background: #fff;
      border: 1px solid var(--border-light);
      border-radius: 26px;
      padding: clamp(24px, 5vw, 46px);
      box-shadow: 0 18px 56px rgba(43,43,43,.055);
    }

    .oa-answer-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 26px;
      align-items: start;
    }

    .oa-answer h2 {
      font-family: var(--font-heading);
      font-size: clamp(34px, 5vw, 56px);
      line-height: 1;
      letter-spacing: -.06em;
      margin: 0 0 16px;
    }

    .oa-answer p {
      color: var(--text-secondary);
      line-height: 1.7;
      font-size: 17px;
    }

    .oa-summary {
      background: var(--surface-2);
      border: 1px solid var(--border-light);
      border-radius: 20px;
      padding: 20px;
    }

    .oa-summary ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 10px;
      font-size: 14px;
      color: var(--text-secondary);
    }

    .oa-summary strong {
      color: var(--text-primary);
    }

    .oa-final {
      background: var(--sidebar-bg);
      color: var(--sidebar-text);
      padding: clamp(64px, 9vw, 110px) 0;
      text-align: center;
    }

    .oa-final h2 {
      font-family: var(--font-heading);
      font-size: clamp(34px, 5vw, 58px);
      line-height: 1;
      letter-spacing: -.06em;
      margin: 0 0 14px;
    }

    .oa-final p {
      color: var(--sidebar-muted);
      max-width: 620px;
      margin: 0 auto 28px;
      line-height: 1.7;
    }

    .oa-loading {
      padding: 28px;
      border: 1px dashed var(--border-light);
      border-radius: 22px;
      color: var(--text-muted);
      background: rgba(255,255,255,.55);
    }

    @media (max-width: 900px) {
      .oa-hero-grid,
      .oa-answer-grid {
        grid-template-columns: 1fr;
      }

      .oa-stat-grid {
        grid-template-columns: 1fr;
      }
    }
  
    /* Homepage D1 card polish */
    .oa-grid {
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 360px));
      justify-content: start;
      align-items: stretch;
    }

    .oa-card {
      width: 100%;
      max-width: 360px;
    }

    .oa-card-img {
      height: 170px;
      object-fit: cover;
      object-position: top center;
    }

    .oa-card h3 {
      overflow-wrap: anywhere;
    }

    .oa-card-foot {
      flex-wrap: wrap;
      row-gap: 8px;
    }

    .oa-card-foot span:first-child {
      max-width: 100%;
      overflow-wrap: anywhere;
    }

    .oa-section-head .oa-button {
      white-space: nowrap;
    }

    @media (max-width: 760px) {
      .oa-grid {
        grid-template-columns: 1fr;
      }

      .oa-card {
        max-width: none;
      }

      .oa-card-img {
        height: 190px;
      }
    }
  </style>

  <main class="oa-page">
    <section class="oa-hero" aria-labelledby="hero-title">
      <div class="oa-wrap oa-hero-grid">
        <div>
          <span class="oa-kicker">Offline-first tools - buy once - own forever</span>
          <h1 class="oa-h1" id="hero-title">
            Own your tools.<br />
            Own your data.<br />
            <span class="oa-gold">Own your system.</span>
          </h1>
          <p class="oa-lede">
            OwnitApps builds private, offline-first digital tools for people who are tired of monthly software,
            forced accounts, cloud lock-in, and losing access to their own workflows.
          </p>

          <div class="oa-actions">
            <a class="oa-button gold" href="/apps-live">Browse live apps</a>
            <a class="oa-button" href="/pseo-live">Explore use cases</a>
            <a class="oa-button" href="/start-here">Start here</a>
          </div>

          <div class="oa-trust-row" aria-label="OwnitApps principles">
            <span class="oa-pill">No forced account</span>
            <span class="oa-pill">No monthly subscription</span>
            <span class="oa-pill">Local-first data</span>
            <span class="oa-pill">Buy once</span>
          </div>
        </div>

        <aside class="oa-hero-panel" aria-label="Live OwnitApps CMS overview">
          <h2 class="oa-panel-title">Live OwnitApps index</h2>
          <div class="oa-stat-grid">
            <div class="oa-stat">
              <strong id="homeCountProducts">-</strong>
              <span>Products</span>
            </div>
            <div class="oa-stat">
              <strong id="homeCountPseo">-</strong>
              <span>pSEO pages</span>
            </div>
            <div class="oa-stat">
              <strong id="homeCountPosts">-</strong>
              <span>Articles</span>
            </div>
          </div>

          <div class="oa-mini-list" id="homeMiniList">
            <div class="oa-mini-item">
              <span>Loading live D1 content...</span>
              <span>CMS</span>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="oa-strip" aria-label="OwnitApps value strip">
      <div class="oa-wrap oa-strip-inner">
        <span class="oa-pill">Offline-first</span>
        <span class="oa-pill">Private by default</span>
        <span class="oa-pill">No forced subscriptions</span>
        <span class="oa-pill">Local ownership</span>
        <span class="oa-pill">No account required</span>
        <span class="oa-pill">Lifetime utility</span>
      </div>
    </section>

    <section class="oa-section" aria-labelledby="apps-title">
      <div class="oa-wrap">
        <div class="oa-section-head">
          <div>
            <span class="oa-kicker">Live products</span>
            <h2 class="oa-section-title" id="apps-title">Tools that stay yours</h2>
            <p class="oa-section-copy">
              Published OwnitApps products from the live D1 CMS. Each tool is designed around ownership,
              local-first data, and practical use without subscription pressure.
            </p>
          </div>
          <a class="oa-button" href="/apps-live">View all products</a>
        </div>

        <div class="oa-grid" id="homeProducts">
          <div class="oa-loading">Loading products from D1...</div>
        </div>
      </div>
    </section>

    <section class="oa-section alt" aria-labelledby="problem-title">
      <div class="oa-wrap">
        <div class="oa-section-head">
          <div>
            <span class="oa-kicker">Why OwnitApps exists</span>
            <h2 class="oa-section-title" id="problem-title">The subscription era has a problem</h2>
            <p class="oa-section-copy">
              Most modern software asks you to rent access, upload personal data, and depend on a remote account.
              OwnitApps is built in the opposite direction.
            </p>
          </div>
        </div>

        <div class="oa-problem-grid">
          <article class="oa-problem">
            <strong>Subscription fatigue</strong>
            <p>Useful tools should not become permanent bills. OwnitApps favors buy-once tools with long-term utility.</p>
          </article>
          <article class="oa-problem">
            <strong>Cloud lock-in</strong>
            <p>Your personal workflows should not disappear because a remote service changed pricing or shut down.</p>
          </article>
          <article class="oa-problem">
            <strong>Forced accounts</strong>
            <p>Core tools should work without registration, password resets, or unnecessary identity collection.</p>
          </article>
          <article class="oa-problem">
            <strong>Data ownership</strong>
            <p>Private planning data belongs on your device first, with export and backup options you control.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="oa-section" aria-labelledby="pseo-title">
      <div class="oa-wrap">
        <div class="oa-section-head">
          <div>
            <span class="oa-kicker">Use cases and discovery</span>
            <h2 class="oa-section-title" id="pseo-title">Find the right private tool</h2>
            <p class="oa-section-copy">
              Explore live long-tail pages about offline tools, no-subscription software, privacy-first workflows,
              and local-first use cases.
            </p>
          </div>
          <a class="oa-button" href="/pseo-live">View all pSEO pages</a>
        </div>

        <div class="oa-grid" id="homePseo">
          <div class="oa-loading">Loading pSEO pages from D1...</div>
        </div>
      </div>
    </section>

    <section class="oa-section alt" aria-labelledby="blog-title">
      <div class="oa-wrap">
        <div class="oa-section-head">
          <div>
            <span class="oa-kicker">Guides and articles</span>
            <h2 class="oa-section-title" id="blog-title">Latest thinking from OwnitApps</h2>
            <p class="oa-section-copy">
              Published articles from the live D1 CMS.
            </p>
          </div>
          <a class="oa-button" href="/blog-live">View all articles</a>
        </div>

        <div class="oa-grid" id="homePosts">
          <div class="oa-loading">Loading articles from D1...</div>
        </div>
      </div>
    </section>

    <section class="oa-section" aria-labelledby="answer-title">
      <div class="oa-wrap">
        <div class="oa-answer">
          <div class="oa-answer-grid">
            <div>
              <span class="oa-kicker">Source of truth</span>
              <h2 id="answer-title">What is OwnitApps?</h2>
              <p>
                OwnitApps is a collection of offline-first digital tools designed for people who want practical software
                without forced subscriptions, cloud dependency, or required accounts.
              </p>
              <p>
                The core promise is simple: Your OS. Your Data. Your Rules. Tools should help you manage life,
                money, projects, records, and decisions without taking ownership away from you.
              </p>
              <div class="oa-actions">
                <a class="oa-button" href="/what-is-ownitapps">Full explanation</a>
                <a class="oa-button" href="/offline-first-apps">Offline-first apps</a>
              </div>
            </div>

            <aside class="oa-summary">
              <ul>
                <li><strong>Brand:</strong> OwnitApps</li>
                <li><strong>Category:</strong> Offline-first digital tools</li>
                <li><strong>Business model:</strong> Buy once, use forever</li>
                <li><strong>Data model:</strong> Local-first, private by default</li>
                <li><strong>Target user:</strong> People tired of subscriptions and cloud lock-in</li>
                <li><strong>Official site:</strong> ownitapps.com</li>
                <li><strong>Brand promise:</strong> Your OS. Your Data. Your Rules.</li>
              </ul>
            </aside>
          </div>
        </div>
      </div>
    </section>

    <section class="oa-final">
      <div class="oa-wrap">
        <span class="oa-kicker" style="color: var(--gold);">Build your private OS</span>
        <h2>Your OS. Your Data. Your Rules.</h2>
        <p>
          Start with one tool. Build a private system over time. Keep your data close,
          your workflows portable, and your software costs predictable.
        </p>
        <div class="oa-actions" style="justify-content:center;">
          <a class="oa-button gold" href="/apps-live">Browse live apps</a>
          <a class="oa-button" href="/pseo-live">Explore use cases</a>
        </div>
      </div>
    </section>
  </main>

  <script>
    const escapeHtml = (value) =>
      String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");

    const trimText = (value, limit = 150) => {
      const text = String(value || "").trim();
      if (text.length <= limit) return text;
      return text.slice(0, limit).replace(/\s+\S*$/, "") + "...";
    };

    const setText = (id, value) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(value ?? 0);
    };

    const cardImage = (src, alt) => {
      if (!src) return "";
      return `<img class="oa-card-img" src="${escapeHtml(src)}" alt="${escapeHtml(alt)}" loading="lazy">`;
    };

    const productCard = (product) => {
      const title = product.name || "Untitled Product";
      const desc = product.description || product.tagline || "Private, local-first software by OwnitApps.";
      const price = product.price ? `${product.price} ${product.currency || "USD"}` : "Price not set";

      return `
        <a class="oa-card" href="/apps-live/${encodeURIComponent(product.slug || "")}" aria-label="${escapeHtml(title)}">
          ${cardImage(product.og_image, title)}
          <div class="oa-card-body">
            <div class="oa-badges">
              <span class="oa-badge">${escapeHtml(product.category || "OwnitApps")}</span>
              <span class="oa-badge">Published</span>
            </div>
            <h3>${escapeHtml(title)}</h3>
            <p>${escapeHtml(trimText(desc, 180))}</p>
            <div class="oa-card-foot">
              <span>${escapeHtml(price)}</span>
              <span>Open product</span>
            </div>
          </div>
        </a>
      `;
    };

    const pseoCard = (page) => {
      const title = page.title || "Untitled pSEO Page";
      const desc = page.intro || page.seo_description || "OwnitApps long-tail page.";

      return `
        <a class="oa-card" href="/pseo-live/${encodeURIComponent(page.slug || "")}" aria-label="${escapeHtml(title)}">
          ${cardImage(page.og_image, title)}
          <div class="oa-card-body">
            <div class="oa-badges">
              <span class="oa-badge">${escapeHtml(page.pattern || "pSEO")}</span>
              <span class="oa-badge">${escapeHtml(page.search_intent || "intent")}</span>
            </div>
            <h3>${escapeHtml(title)}</h3>
            <p>${escapeHtml(trimText(desc, 180))}</p>
            <div class="oa-card-foot">
              <span>${escapeHtml(page.target_keyword || "keyword")}</span>
              <span>Read page</span>
            </div>
          </div>
        </a>
      `;
    };

    const postCard = (post) => {
      const title = post.title || "Untitled Article";
      const desc = post.excerpt || post.seo_description || "OwnitApps article.";

      return `
        <a class="oa-card" href="/blog-live/${encodeURIComponent(post.slug || "")}" aria-label="${escapeHtml(title)}">
          ${cardImage(post.og_image, title)}
          <div class="oa-card-body">
            <div class="oa-badges">
              <span class="oa-badge">${escapeHtml(post.category || "Article")}</span>
            </div>
            <h3>${escapeHtml(title)}</h3>
            <p>${escapeHtml(trimText(desc, 180))}</p>
            <div class="oa-card-foot">
              <span>${escapeHtml(String(post.modified_at || post.created_at || "").slice(0, 10))}</span>
              <span>Read article</span>
            </div>
          </div>
        </a>
      `;
    };

    const fallbackCard = (title, desc, badge, href = "/start-here") => `
      <a class="oa-card" href="${href}" aria-label="${escapeHtml(title)}">
        <div class="oa-card-body">
          <div class="oa-badges">
            <span class="oa-badge">${escapeHtml(badge)}</span>
            <span class="oa-badge">Offline-first</span>
          </div>
          <h3>${escapeHtml(title)}</h3>
          <p>${escapeHtml(desc)}</p>
          <span class="oa-card-link">Explore OwnitApps →</span>
        </div>
      </a>
    `;

    const fallbackSets = {
      homeProducts: [
        fallbackCard("Budget by Paycheck OS", "A private, buy-once planner for paycheck budgeting, bills, savings, and monthly control.", "Finance tool", "/apps"),
        fallbackCard("Home Admin Binder OS", "Keep household records, renewals, documents, and emergency details organized without another subscription.", "Home system", "/apps"),
        fallbackCard("Medical Binder OS", "A local-first family health vault for medications, appointments, records, and printable emergency notes.", "Health vault", "/apps")
      ],
      homePseo: [
        fallbackCard("Offline Budget Planner for Freelancers", "Explore how local-first budget tools help freelancers plan irregular income without cloud lock-in.", "Use case", "/pseo-live"),
        fallbackCard("Private Family Document Organizer", "A practical guide to owning important household records instead of scattering them across cloud apps.", "Privacy-first", "/pseo-live"),
        fallbackCard("No-Subscription Personal Dashboard", "Compare buy-once tools with recurring SaaS dashboards for daily life, money, and home systems.", "No subscription", "/pseo-live")
      ],
      homePosts: [
        fallbackCard("Why Offline-First Apps Are Coming Back", "A clear explanation of why people want tools that still work when accounts, servers, or subscriptions fail.", "Article", "/blog"),
        fallbackCard("Subscription Fatigue and How to Escape It", "Understand the hidden cost of permanent software bills and how buy-once tools change the equation.", "Guide", "/blog"),
        fallbackCard("Local-First Software Explained", "A simple breakdown of local data ownership, browser storage, exports, and private workflows.", "Explainer", "/blog")
      ]
    };

    const renderList = (id, items, renderer, emptyText) => {
      const el = document.getElementById(id);
      if (!el) return;

      if (!items || !items.length) {
        el.innerHTML = (fallbackSets[id] || [
          fallbackCard("OwnitApps is ready", emptyText, "Local preview", "/start-here")
        ]).join("");
        return;
      }

      el.innerHTML = items.map(renderer).join("");
    };

    const renderMiniList = (data) => {
      const el = document.getElementById("homeMiniList");
      if (!el) return;

      const items = [];

      if (data.products?.[0]) {
        items.push({
          label: data.products[0].name || "Latest product",
          type: "Product"
        });
      }

      if (data.pseo?.[0]) {
        items.push({
          label: data.pseo[0].title || "Latest pSEO page",
          type: "pSEO"
        });
      }

      if (data.posts?.[0]) {
        items.push({
          label: data.posts[0].title || "Latest article",
          type: "Article"
        });
      }

      if (!items.length) {
        el.innerHTML = `
          <div class="oa-mini-item">
            <span>No published D1 content yet</span>
            <span>CMS</span>
          </div>
        `;
        return;
      }

      el.innerHTML = items.map((item) => `
        <div class="oa-mini-item">
          <span>${escapeHtml(trimText(item.label, 44))}</span>
          <span>${escapeHtml(item.type)}</span>
        </div>
      `).join("");
    };

    async function loadHomeData() {
      try {
        const res = await fetch("/api/public/home", { headers: { "accept": "application/json" } });
        const data = await res.json();

        if (!res.ok || data.ok === false) throw new Error(data.error || "Failed to load homepage data");

        setText("homeCountProducts", data.counts?.products ?? 0);
        setText("homeCountPseo", data.counts?.pseo ?? 0);
        setText("homeCountPosts", data.counts?.posts ?? 0);

        renderMiniList(data);
        renderList("homeProducts", data.products, productCard, "No published products yet.");
        renderList("homePseo", data.pseo, pseoCard, "No published pSEO pages yet.");
        renderList("homePosts", data.posts, postCard, "No published articles yet.");
      } catch (error) {
        renderList("homeProducts", [], productCard, "Could not load products.");
        renderList("homePseo", [], pseoCard, "Could not load pSEO pages.");
        renderList("homePosts", [], postCard, "Could not load articles.");
      }
    }

    loadHomeData();
  </script>
</PublicLayout>