---
import { getCollection } from 'astro:content';
import AdminLayout from '@layouts/AdminLayout.astro';
import { auditInternalLinks, type LinkNode } from '@lib/internal-links';

// Build node list from all content collections
const [blogs, products, pseoPages, glossaryTerms] = await Promise.all([
  getCollection('blog'),
  getCollection('products'),
  getCollection('pseo'),
  getCollection('glossary'),
]);

const nodes: LinkNode[] = [
  ...blogs.map((b) => ({
    slug: b.slug,
    url: `/blog/${b.slug}`,
    title: b.data.title,
    type: 'blog' as const,
    category: b.data.category,
    tags: b.data.tags ?? [],
    relatedProducts: b.data.relatedProducts ?? [],
  })),
  ...products.map((p) => ({
    slug: p.slug,
    url: `/apps/${p.slug}`,
    title: p.data.name,
    type: 'product' as const,
    category: p.data.category,
    tags: [],
  })),
  ...pseoPages.map((p) => ({
    slug: p.slug,
    url: `/${p.data.pattern}/${p.slug}`,
    title: p.data.title,
    type: 'pseo' as const,
    relatedProducts: p.data.relatedProducts ?? [],
  })),
  ...glossaryTerms.map((g) => ({
    slug: g.slug,
    url: `/glossary/${g.slug}`,
    title: g.data.term,
    type: 'glossary' as const,
    relatedProducts: g.data.relatedProducts ?? [],
  })),
];

const audit = auditInternalLinks(nodes);
const highSuggestions = audit.suggestions.filter((s) => s.priority === 'high');
const medSuggestions = audit.suggestions.filter((s) => s.priority === 'medium');

// Score color
const scoreColor =
  audit.score >= 80 ? 'text-emerald-400' : audit.score >= 60 ? 'text-amber-400' : 'text-red-400';

// Type badge colors
const typeBadgeClass = (type: string) => {
  switch (type) {
    case 'blog':     return 'bg-blue-500/10 text-blue-400 border-blue-500/20';
    case 'product':  return 'bg-[var(--gold)]/10 text-[var(--gold)] border-[var(--gold)]/20';
    case 'pseo':     return 'bg-purple-500/10 text-purple-400 border-purple-500/20';
    case 'glossary': return 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20';
    default:         return 'bg-white/5 text-white/60 border-white/10';
  }
};
---

<AdminLayout title="Internal Links Audit">
  <div class="p-8 max-w-6xl">

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold font-heading text-white mb-1">Internal Links Audit</h1>
      <p class="text-[var(--text-muted)] text-sm">
        Orphan detection, link graph analysis, and anchor text suggestions across all content.
      </p>
    </div>

    <!-- Score + summary cards -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      <div class="p-5 rounded-xl border border-white/10 bg-white/3 text-center">
        <div class={`text-4xl font-bold font-heading mb-1 ${scoreColor}`}>{audit.score}</div>
        <div class="text-xs text-[var(--text-muted)]">Link Health Score</div>
      </div>
      <div class="p-5 rounded-xl border border-white/10 bg-white/3 text-center">
        <div class="text-4xl font-bold font-heading text-white mb-1">{audit.totalPages}</div>
        <div class="text-xs text-[var(--text-muted)]">Total Pages</div>
      </div>
      <div class="p-5 rounded-xl border border-white/10 bg-white/3 text-center">
        <div class={`text-4xl font-bold font-heading mb-1 ${audit.orphanPages.length > 0 ? 'text-red-400' : 'text-emerald-400'}`}>
          {audit.orphanPages.length}
        </div>
        <div class="text-xs text-[var(--text-muted)]">Orphan Pages</div>
      </div>
      <div class="p-5 rounded-xl border border-white/10 bg-white/3 text-center">
        <div class={`text-4xl font-bold font-heading mb-1 ${highSuggestions.length > 0 ? 'text-amber-400' : 'text-emerald-400'}`}>
          {highSuggestions.length}
        </div>
        <div class="text-xs text-[var(--text-muted)]">High-Priority Links Needed</div>
      </div>
    </div>

    <!-- Issues banner -->
    {audit.issues.length > 0 && (
      <div class="mb-8 p-4 rounded-xl border border-amber-500/20 bg-amber-500/5">
        <p class="text-xs font-mono text-amber-400 mb-2 uppercase tracking-wide">Issues Found</p>
        <ul class="space-y-1">
          {audit.issues.map((issue) => (
            <li class="text-sm text-amber-200/80 flex items-start gap-2">
              <span class="text-amber-400 flex-shrink-0">⚠</span>
              <span>{issue}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Orphan pages -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
        <span class="text-red-400">●</span> Orphan Pages
        <span class="text-xs font-normal text-[var(--text-muted)] ml-1">(zero inbound internal links)</span>
      </h2>
      {audit.orphanPages.length === 0 ? (
        <div class="p-5 rounded-xl border border-emerald-500/20 bg-emerald-500/5 text-center">
          <p class="text-emerald-400 text-sm font-medium">✓ No orphan pages detected</p>
        </div>
      ) : (
        <div class="rounded-xl border border-white/10 overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-white/5 border-b border-white/10">
              <tr>
                <th class="text-left py-3 px-4 text-[var(--text-muted)] font-medium">Page</th>
                <th class="text-left py-3 px-4 text-[var(--text-muted)] font-medium">Type</th>
                <th class="text-right py-3 px-4 text-[var(--text-muted)] font-medium">In</th>
                <th class="text-right py-3 px-4 text-[var(--text-muted)] font-medium">Out</th>
              </tr>
            </thead>
            <tbody>
              {audit.orphanPages.map((page) => (
                <tr class="border-b border-white/5 hover:bg-white/2">
                  <td class="py-3 px-4">
                    <a href={page.url} class="text-white hover:text-[var(--gold)] transition-colors font-mono text-xs">
                      {page.url}
                    </a>
                    <div class="text-[var(--text-muted)] text-xs mt-0.5">{page.title}</div>
                  </td>
                  <td class="py-3 px-4">
                    <span class={`text-xs px-2 py-0.5 rounded-full border ${typeBadgeClass(page.type)}`}>
                      {page.type}
                    </span>
                  </td>
                  <td class="py-3 px-4 text-right text-red-400 font-mono text-xs font-bold">{page.inboundLinks}</td>
                  <td class="py-3 px-4 text-right text-white/60 font-mono text-xs">{page.outboundLinks}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <!-- Link suggestions — high priority -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
        <span class="text-amber-400">●</span> High-Priority Link Suggestions
        <span class="text-xs font-normal text-[var(--text-muted)] ml-1">({highSuggestions.length})</span>
      </h2>
      {highSuggestions.length === 0 ? (
        <div class="p-5 rounded-xl border border-emerald-500/20 bg-emerald-500/5 text-center">
          <p class="text-emerald-400 text-sm font-medium">✓ No high-priority gaps found</p>
        </div>
      ) : (
        <div class="space-y-3">
          {highSuggestions.slice(0, 15).map((s) => (
            <div class="p-4 rounded-xl border border-amber-500/15 bg-amber-500/3">
              <div class="flex items-start justify-between gap-4 mb-2">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 text-xs font-mono mb-1">
                    <span class="text-white/60 truncate">{s.fromUrl}</span>
                    <span class="text-amber-400 flex-shrink-0">→</span>
                    <span class="text-[var(--gold)] truncate">{s.toUrl}</span>
                  </div>
                  <div class="text-white text-sm font-medium truncate">{s.fromTitle}</div>
                </div>
              </div>
              <div class="flex items-center gap-3 text-xs">
                <span class="text-[var(--text-muted)]">Anchor:</span>
                <code class="px-2 py-0.5 rounded bg-white/5 text-[var(--gold)]">
                  {s.anchorText}
                </code>
                <span class="text-[var(--text-muted)] flex-1 truncate">{s.reason}</span>
              </div>
            </div>
          ))}
          {highSuggestions.length > 15 && (
            <p class="text-xs text-[var(--text-muted)] text-center pt-2">
              + {highSuggestions.length - 15} more high-priority suggestions
            </p>
          )}
        </div>
      )}
    </section>

    <!-- Link suggestions — medium priority -->
    {medSuggestions.length > 0 && (
      <section class="mb-10">
        <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
          <span class="text-blue-400">●</span> Medium-Priority Link Suggestions
          <span class="text-xs font-normal text-[var(--text-muted)] ml-1">({medSuggestions.length})</span>
        </h2>
        <div class="space-y-3">
          {medSuggestions.slice(0, 10).map((s) => (
            <div class="p-4 rounded-xl border border-white/8 bg-white/2">
              <div class="flex items-center gap-2 text-xs font-mono mb-2">
                <span class="text-white/60 truncate">{s.fromUrl}</span>
                <span class="text-blue-400 flex-shrink-0">→</span>
                <span class="text-white/80 truncate">{s.toUrl}</span>
              </div>
              <div class="flex items-center gap-3 text-xs">
                <span class="text-[var(--text-muted)]">Anchor:</span>
                <code class="px-2 py-0.5 rounded bg-white/5 text-[var(--gold)]">{s.anchorText}</code>
                <span class="text-[var(--text-muted)] flex-1 truncate">{s.reason}</span>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Well-linked pages -->
    <section>
      <h2 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
        <span class="text-emerald-400">●</span> Well-Linked Pages
        <span class="text-xs font-normal text-[var(--text-muted)] ml-1">(2+ inbound links)</span>
      </h2>
      {audit.wellLinkedPages.length === 0 ? (
        <p class="text-sm text-[var(--text-muted)]">No pages with 2+ inbound links yet. Keep building internal links!</p>
      ) : (
        <div class="grid sm:grid-cols-2 gap-3">
          {audit.wellLinkedPages.map((page) => (
            <div class="flex items-center justify-between p-4 rounded-xl border border-white/8 bg-white/2">
              <div class="min-w-0 flex-1">
                <a href={page.url} class="text-white text-sm font-medium hover:text-[var(--gold)] transition-colors truncate block">
                  {page.title}
                </a>
                <span class="font-mono text-xs text-[var(--text-muted)]">{page.url}</span>
              </div>
              <div class="flex items-center gap-2 ml-4 flex-shrink-0">
                <span class={`text-xs px-2 py-0.5 rounded-full border ${typeBadgeClass(page.type)}`}>
                  {page.type}
                </span>
                <span class="text-emerald-400 font-mono text-xs font-bold">
                  ↑{audit.inboundCounts.get(page.url) ?? 0}
                </span>
              </div>
            </div>
          ))}
        </div>
      )}
    </section>

  </div>
</AdminLayout>
