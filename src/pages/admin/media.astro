---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Media Library | OwnitApps Admin</title>
    <style>
      :root {
        --sidebar-bg: #2B2B2B;
        --sidebar-text: #E8DDD0;
        --sidebar-muted: #9A8F82;
        --sidebar-border: #3A3A3A;
        --main-bg: #F5F0E8;
        --card: #FFFFFF;
        --surface-2: #F0EBE0;
        --border-light: rgba(0,0,0,0.07);
        --border-medium: rgba(0,0,0,0.12);
        --gold: #C9A84C;
        --gold-hover: #B8932E;
        --green: #2E8B5A;
        --red: #C0392B;
        --blue: #2471A3;
        --text-primary: #2B2B2B;
        --text-secondary: #6B6258;
        --text-muted: #9A8F82;
        --r: 10px;
        --rs: 6px;
        --font-heading: "Syne", "Inter", "Segoe UI", system-ui, sans-serif;
        --font-body: "DM Sans", "Inter", "Segoe UI", system-ui, sans-serif;
        --font-mono: "DM Mono", "SFMono-Regular", Consolas, monospace;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        background: var(--main-bg);
        color: var(--text-primary);
        font-family: var(--font-body);
      }

      .shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 240px 1fr;
      }

      aside {
        background: var(--sidebar-bg);
        color: var(--sidebar-text);
        padding: 24px 18px;
        border-right: 1px solid var(--sidebar-border);
      }

      .brand {
        font-family: var(--font-heading);
        font-weight: 800;
        letter-spacing: -0.03em;
        font-size: 22px;
        margin-bottom: 6px;
      }

      aside .muted {
        color: var(--sidebar-muted);
        font-size: 12px;
        line-height: 1.5;
      }

      nav {
        display: grid;
        gap: 8px;
        margin-top: 28px;
      }

      nav a {
        color: var(--sidebar-text);
        text-decoration: none;
        padding: 10px 12px;
        border-radius: var(--rs);
        font-size: 14px;
      }

      nav a.active,
      nav a:hover {
        background: rgba(201,168,76,.14);
        color: #fff;
      }

      main {
        padding: 32px;
        max-width: 1400px;
        width: 100%;
      }

      .topbar {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 24px;
      }

      h1 {
        font-family: var(--font-heading);
        font-weight: 800;
        letter-spacing: -0.04em;
        font-size: clamp(32px, 4vw, 52px);
        margin: 0 0 8px;
      }

      .subtitle {
        color: var(--text-secondary);
        max-width: 780px;
        line-height: 1.6;
        margin: 0;
      }

      .grid {
        display: grid;
        grid-template-columns: minmax(320px, 440px) 1fr;
        gap: 20px;
        align-items: start;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--border-light);
        border-radius: var(--r);
        box-shadow: 0 18px 50px rgba(43,43,43,.06);
      }

      .card-body { padding: 18px; }

      h2 {
        font-family: var(--font-heading);
        letter-spacing: -0.03em;
        margin: 0 0 10px;
        font-size: 22px;
      }

      label {
        display: block;
        font-size: 12px;
        font-family: var(--font-mono);
        color: var(--text-secondary);
        margin: 13px 0 6px;
      }

      input {
        width: 100%;
        border: 1px solid var(--border-medium);
        border-radius: var(--rs);
        padding: 10px 12px;
        background: #fff;
        color: var(--text-primary);
        font: inherit;
        min-height: 42px;
      }

      button {
        appearance: none;
        border: 0;
        border-radius: var(--rs);
        padding: 10px 14px;
        min-height: 42px;
        cursor: pointer;
        font-weight: 700;
      }

      .primary { background: var(--gold); color: #1f1f1f; }
      .primary:hover { background: var(--gold-hover); }

      .secondary {
        background: var(--surface-2);
        color: var(--text-primary);
        border: 1px solid var(--border-medium);
      }

      .drop {
        border: 2px dashed var(--border-medium);
        border-radius: var(--r);
        background: rgba(255,255,255,.65);
        padding: 26px;
        text-align: center;
        color: var(--text-secondary);
        margin: 14px 0;
      }

      .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 16px;
      }

      .small {
        font-size: 12px;
        color: var(--text-muted);
        line-height: 1.5;
      }

      .result {
        display: none;
        margin-top: 16px;
        padding: 14px;
        border-radius: var(--r);
        background: var(--surface-2);
        border: 1px solid var(--border-light);
      }

      .result.show { display: block; }

      .result code {
        display: block;
        white-space: pre-wrap;
        word-break: break-word;
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--text-secondary);
      }

      .toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 14px;
      }

      .search {
        max-width: 320px;
      }

      .media-list {
        display: grid;
        gap: 10px;
      }

      .media-item {
        padding: 14px;
        border: 1px solid var(--border-light);
        border-radius: var(--r);
        background: #fff;
      }

      .media-title {
        font-weight: 800;
        margin-bottom: 4px;
      }

      .media-meta {
        font-family: var(--font-mono);
        color: var(--text-muted);
        font-size: 12px;
        display: grid;
        gap: 4px;
        word-break: break-word;
      }

      .pill {
        display: inline-flex;
        width: fit-content;
        padding: 3px 8px;
        border-radius: 999px;
        background: rgba(201,168,76,.14);
        color: #806515;
        border: 1px solid rgba(201,168,76,.24);
        font-family: var(--font-mono);
        font-size: 11px;
        margin-bottom: 8px;
      }


      .media-item {
        display: grid;
        gap: 10px;
        padding: 16px;
        border: 1px solid var(--border-light);
        border-radius: var(--r);
        background: #fff;
        box-shadow: 0 10px 30px rgba(43,43,43,.04);
      }

      .media-title {
        font-family: var(--font-heading);
        font-weight: 850;
        font-size: 17px;
        line-height: 1.25;
        margin-bottom: 2px;
      }

      .media-meta {
        display: grid;
        gap: 7px;
        font-family: var(--font-mono);
        color: var(--text-muted);
        font-size: 12px;
        line-height: 1.45;
      }

      .media-meta span {
        min-width: 0;
        overflow-wrap: anywhere;
      }

      .media-meta a {
        color: #806515;
        font-weight: 700;
      }

      .media-meta button {
        width: fit-content;
        min-height: 34px;
        padding: 7px 10px;
      }

      .toast {
        position: fixed;
        right: 18px;
        bottom: 18px;
        background: var(--sidebar-bg);
        color: var(--sidebar-text);
        padding: 12px 14px;
        border-radius: var(--r);
        box-shadow: 0 18px 60px rgba(0,0,0,.22);
        display: none;
        z-index: 999;
        max-width: 360px;
      }

      .toast.show { display: block; }

      @media (max-width: 980px) {
        .shell { grid-template-columns: 1fr; }
        nav { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        main { padding: 20px; padding-bottom: 100px; }
        .grid { grid-template-columns: 1fr; }
        .topbar { display: block; }
      }
    
      /* FORCED_ADMIN_LIST_POLISH */
      .post-list,
      .product-list,
      .media-list,
      #pages {
        display: grid !important;
        gap: 12px !important;
      }

      .post-item,
      .product-item,
      .media-item,
      #pages .item {
        display: grid !important;
        grid-template-columns: minmax(0, 1fr) auto !important;
        align-items: start !important;
        gap: 14px !important;
        padding: 16px !important;
        border: 1px solid var(--border-light, rgba(0,0,0,.08)) !important;
        border-radius: var(--r, 10px) !important;
        background: #fff !important;
        box-shadow: 0 10px 30px rgba(43,43,43,.045) !important;
        margin: 0 0 12px !important;
      }

      .media-item {
        grid-template-columns: minmax(0, 1fr) !important;
      }

      .post-title,
      .product-title,
      .media-title,
      #pages .title {
        display: block !important;
        font-family: var(--font-heading, system-ui) !important;
        font-weight: 850 !important;
        font-size: 17px !important;
        line-height: 1.25 !important;
        margin: 0 0 10px !important;
        max-width: 760px !important;
        color: var(--text-primary, #2B2B2B) !important;
      }

      .post-meta,
      .product-meta,
      .media-meta,
      #pages .meta {
        display: flex !important;
        flex-wrap: wrap !important;
        align-items: center !important;
        gap: 7px !important;
        color: var(--text-muted, #9A8F82) !important;
        font-family: var(--font-mono, monospace) !important;
        font-size: 12px !important;
        line-height: 1.4 !important;
      }

      .post-meta > span,
      .product-meta > span,
      #pages .meta > span,
      .media-meta > span {
        display: inline-flex !important;
        align-items: center !important;
        max-width: 280px !important;
        min-width: 0 !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        white-space: nowrap !important;
        padding: 4px 8px !important;
        border-radius: 999px !important;
        background: var(--surface-2, #F0EBE0) !important;
        border: 1px solid var(--border-light, rgba(0,0,0,.08)) !important;
      }

      .media-meta > span {
        max-width: 100% !important;
        white-space: normal !important;
        overflow-wrap: anywhere !important;
      }

      .badge,
      #pages .badge,
      .post-meta .badge,
      .product-meta .badge {
        display: inline-flex !important;
        align-items: center !important;
        padding: 4px 8px !important;
        border-radius: 999px !important;
        background: var(--surface-2, #F0EBE0) !important;
        border: 1px solid var(--border-light, rgba(0,0,0,.08)) !important;
        color: var(--text-muted, #9A8F82) !important;
      }

      .badge.published,
      #pages .badge.published,
      .post-meta .badge.published,
      .product-meta .badge.published {
        color: var(--green, #2E8B5A) !important;
        background: rgba(46,139,90,.10) !important;
        border-color: rgba(46,139,90,.22) !important;
      }

      .post-item button,
      .product-item button,
      #pages .item button,
      .media-item button {
        justify-self: end !important;
        min-height: 34px !important;
        padding: 7px 11px !important;
        border-radius: var(--rs, 6px) !important;
      }

      .media-meta a {
        color: #806515 !important;
        font-weight: 800 !important;
        overflow-wrap: anywhere !important;
      }

      @media (max-width: 900px) {
        .post-item,
        .product-item,
        #pages .item {
          grid-template-columns: 1fr !important;
        }

        .post-item button,
        .product-item button,
        #pages .item button {
          justify-self: start !important;
        }
      }
      /* /FORCED_ADMIN_LIST_POLISH */
    
      /* ADMIN_POLISH_V2 */
      .list,
      .post-list,
      .product-list,
      .media-list,
      #pages {
        display: grid !important;
        gap: 14px !important;
      }

      .item,
      .post-item,
      .product-item,
      .media-item,
      #pages .item {
        display: grid !important;
        grid-template-columns: minmax(0, 1fr) auto !important;
        align-items: start !important;
        gap: 16px !important;
        padding: 18px !important;
        border: 1px solid rgba(0,0,0,.08) !important;
        border-radius: 10px !important;
        background: #fff !important;
        box-shadow: 0 14px 36px rgba(43,43,43,.055) !important;
        margin: 0 0 12px !important;
      }

      .media-item {
        grid-template-columns: minmax(0, 1fr) !important;
      }

      .item-title,
      .post-title,
      .product-title,
      .media-title,
      #pages .title {
        display: block !important;
        font-weight: 850 !important;
        font-size: 17px !important;
        line-height: 1.25 !important;
        margin: 0 0 10px !important;
        color: #2B2B2B !important;
      }

      .item-meta,
      .post-meta,
      .product-meta,
      .media-meta,
      #pages .meta {
        display: flex !important;
        flex-wrap: wrap !important;
        align-items: center !important;
        gap: 7px !important;
        color: #9A8F82 !important;
        font-size: 12px !important;
        line-height: 1.4 !important;
      }

      .item-meta > span,
      .post-meta > span,
      .product-meta > span,
      #pages .meta > span,
      .media-meta > span {
        display: inline-flex !important;
        align-items: center !important;
        max-width: 280px !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        white-space: nowrap !important;
        padding: 4px 8px !important;
        border-radius: 999px !important;
        background: #F0EBE0 !important;
        border: 1px solid rgba(0,0,0,.08) !important;
      }

      .media-meta > span {
        max-width: 100% !important;
        white-space: normal !important;
        overflow-wrap: anywhere !important;
      }

      .badge.published {
        color: #2E8B5A !important;
        background: rgba(46,139,90,.10) !important;
        border-color: rgba(46,139,90,.22) !important;
      }
      /* /ADMIN_POLISH_V2 */
    </style>
  </head>

  <body>
    <div class="shell">
      <aside>
        <div class="brand">OwnitApps</div>
        <p class="muted">Private media dashboard. Files are stored in Cloudflare R2.</p>

        <nav>
          <a href="/admin/">Dashboard</a>
          <a href="/admin/posts">Posts</a>
          <a href="/admin/products">Products</a>
          <a class="active" href="/admin/media">Media</a>
          <a href="/admin/pseo">pSEO</a>
          <a href="/admin/seo">SEO</a>
          <a href="/admin/settings">Settings</a>
          <a href="/">View Site</a>
        </nav>
      </aside>

      <main>
        <div class="topbar">
          <div>
            <h1>Media Library</h1>
            <p class="subtitle">
              Upload product screenshots, blog images, OG images, icons, PDFs, and update files to Cloudflare R2. Each upload is also recorded in the D1 media table.
            </p>
          </div>
          <button class="secondary" id="refreshBtn">Refresh Library</button>
        </div>

        <div class="grid">
          <section class="card">
            <div class="card-body">
              <h2>Upload File</h2>
              <p class="small">Allowed: PNG, JPG, WEBP, GIF, SVG, PDF.</p>

              <label for="file">File</label>
              <input id="file" type="file" accept="image/png,image/jpeg,image/webp,image/gif,image/svg+xml,application/pdf" />

              <div class="drop" id="drop">
                Choose a file above, then upload it to R2.
              </div>

              <label for="alt">Alt Text / Description</label>
              <input id="alt" placeholder="Example: Budget by Paycheck dashboard screenshot" />

              <div class="actions">
                <button class="primary" id="uploadBtn">Upload to R2</button>
                <button class="secondary" id="clearBtn">Clear</button>
              </div>

              <div class="result" id="result">
                <strong>Last upload</strong>
                <code id="resultCode"></code>
              </div>
            </div>
          </section>

          <section class="card">
            <div class="card-body">
              <div class="toolbar">
                <div>
                  <h2>Uploaded Media</h2>
                  <p class="small"><span id="count">0</span> file(s) saved in D1.</p>
                </div>
                <input class="search" id="search" placeholder="Search media..." />
              </div>

              <div id="mediaList" class="media-list">
                <div class="media-item">
                  <div class="media-title">Loading media...</div>
                  <div class="media-meta">Reading saved records from D1.</div>
                </div>
              </div>
            </div>
          </section>
        </div>
      </main>
    </div>

    <div class="toast" id="toast"></div>

    <script>
      const els = {
        file: document.getElementById("file"),
        alt: document.getElementById("alt"),
        drop: document.getElementById("drop"),
        uploadBtn: document.getElementById("uploadBtn"),
        clearBtn: document.getElementById("clearBtn"),
        refreshBtn: document.getElementById("refreshBtn"),
        result: document.getElementById("result"),
        resultCode: document.getElementById("resultCode"),
        mediaList: document.getElementById("mediaList"),
        count: document.getElementById("count"),
        search: document.getElementById("search"),
        toast: document.getElementById("toast"),
      };

      let media = [];

      function toast(message) {
        els.toast.textContent = message;
        els.toast.classList.add("show");
        setTimeout(() => els.toast.classList.remove("show"), 2600);
      }

      function publicUrl(item) {
        if (!item || !item.r2_key) return "";
        return `${window.location.origin}/media/${String(item.r2_key).replace(/^\/+/, "")}`;
      }

      async function copyText(value) {
        try {
          await navigator.clipboard.writeText(value);
          toast("Public URL copied.");
        } catch {
          const temp = document.createElement("textarea");
          temp.value = value;
          document.body.appendChild(temp);
          temp.select();
          document.execCommand("copy");
          temp.remove();
          toast("Public URL copied.");
        }
      }

      function formatBytes(bytes) {
        if (!bytes) return "0 B";
        const units = ["B", "KB", "MB", "GB"];
        let size = Number(bytes);
        let index = 0;
        while (size >= 1024 && index < units.length - 1) {
          size /= 1024;
          index++;
        }
        return `${size.toFixed(index ? 1 : 0)} ${units[index]}`;
      }

      function clearForm() {
        els.file.value = "";
        els.alt.value = "";
        els.drop.textContent = "Choose a file above, then upload it to R2.";
      }

      function escapeHtml(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      }

      async function api(path, options = {}) {
        const response = await fetch(path, {
          ...options,
          credentials: "same-origin",
          cache: "no-store",
          headers: {
            "accept": "application/json",
            ...(options.headers || {})
          }
        });
        const data = await response.json().catch(() => ({}));

        if (!response.ok || data.ok === false) {
          throw new Error(data.error || "Request failed.");
        }

        return data;
      }

      async function loadMedia() {
        els.mediaList.innerHTML = `
          <div class="media-item">
            <div class="media-title">Loading media...</div>
            <div class="media-meta">Reading saved records from D1.</div>
          </div>
        `;

        try {
          const data = await api("/api/admin/media");
          media = data.media || [];
          renderMedia();
        } catch (error) {
          els.mediaList.innerHTML = `
            <div class="media-item">
              <div class="media-title">Could not load media</div>
              <div class="media-meta">${escapeHtml(error.message)}</div>
            </div>
          `;
          toast(error.message);
        }
      }

      function renderMedia() {
        const query = els.search.value.trim().toLowerCase();

        const filtered = media.filter((item) => {
          const text = [
            item.filename,
            item.url,
            item.alt,
            item.mime_type,
            item.r2_key,
            item.created_at,
          ].join(" ").toLowerCase();

          return text.includes(query);
        });

        els.count.textContent = String(filtered.length);

        if (!filtered.length) {
          els.mediaList.innerHTML = `
            <div class="media-item">
              <div class="media-title">No media found</div>
              <div class="media-meta">Upload a file or change your search.</div>
            </div>
          `;
          return;
        }

        els.mediaList.innerHTML = filtered.map((item) => `
          <article class="media-item">
            <span class="pill">${escapeHtml(item.mime_type || "file")}</span>
            <div class="media-title">${escapeHtml(item.filename || "Upload")}</div>
            <div class="media-meta">
              <span>Size: ${escapeHtml(formatBytes(item.size))}</span>
              <span>Created: ${escapeHtml(item.created_at || "")}</span>
              <span>R2 key: ${escapeHtml(item.r2_key || "")}</span>
              <span>Internal URL: ${escapeHtml(item.url || "")}</span>
              <span>Public URL: <a href="${escapeHtml(publicUrl(item))}" target="_blank" rel="noopener">${escapeHtml(publicUrl(item))}</a></span>
              <span><button class="secondary" data-copy-url="${escapeHtml(publicUrl(item))}" type="button">Copy Public URL</button></span>
              <span>Alt: ${escapeHtml(item.alt || "")}</span>
            </div>
          </article>
        `).join("");
              document.querySelectorAll("[data-copy-url]").forEach((button) => {
          button.addEventListener("click", () => {
            copyText(button.getAttribute("data-copy-url") || "");
          });
        });
      }

      els.file.addEventListener("change", () => {
        const file = els.file.files && els.file.files[0];
        if (!file) {
          els.drop.textContent = "Choose a file above, then upload it to R2.";
          return;
        }

        els.drop.textContent = `${file.name} • ${formatBytes(file.size)} • ${file.type || "unknown type"}`;
      });

      els.clearBtn.addEventListener("click", clearForm);
      els.refreshBtn.addEventListener("click", loadMedia);
      els.search.addEventListener("input", renderMedia);

      els.uploadBtn.addEventListener("click", async () => {
        const file = els.file.files && els.file.files[0];

        if (!file) {
          toast("Choose a file first.");
          return;
        }

        const form = new FormData();
        form.append("file", file);
        form.append("alt", els.alt.value.trim());

        els.uploadBtn.disabled = true;
        els.uploadBtn.textContent = "Uploading...";

        try {
          const response = await fetch("/api/admin/media/upload", {
            method: "POST",
            body: form,
          });

          const data = await response.json().catch(() => ({}));

          if (!response.ok || data.ok === false) {
            throw new Error(data.error || "Upload failed.");
          }

          els.result.classList.add("show");
          els.resultCode.textContent = JSON.stringify(data.media, null, 2);

          toast("Upload saved to R2.");
          clearForm();
          await loadMedia();
        } catch (error) {
          toast(error.message || "Upload failed.");
        } finally {
          els.uploadBtn.disabled = false;
          els.uploadBtn.textContent = "Upload to R2";
        }
      });

      loadMedia();
    </script>
  </body>
</html>
