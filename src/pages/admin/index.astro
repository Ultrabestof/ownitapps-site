    <script>
      const els = {
        postsTotal: document.getElementById("postsTotal"),
        postsDraft: document.getElementById("postsDraft"),
        postsPublished: document.getElementById("postsPublished"),
        productsTotal: document.getElementById("productsTotal"),
        productsDraft: document.getElementById("productsDraft"),
        productsPublished: document.getElementById("productsPublished"),
        mediaTotal: document.getElementById("mediaTotal"),
        pseoTotal: document.getElementById("pseoTotal"),
        pseoDraft: document.getElementById("pseoDraft"),
        pseoPublished: document.getElementById("pseoPublished"),
        recentPosts: document.getElementById("recentPosts"),
        recentProducts: document.getElementById("recentProducts"),
        recentMedia: document.getElementById("recentMedia"),
        recentPseo: document.getElementById("recentPseo"),
        refreshBtn: document.getElementById("refreshBtn"),
      };

      function escapeHtml(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      }

      function setText(id, value) {
        if (els[id]) els[id].textContent = String(value ?? 0);
      }

      function item(title, meta = [], href = "") {
        const inner = `
          <div class="item-title">${escapeHtml(title)}</div>
          <div class="item-meta">
            ${meta.map((m) => `<span class="badge ${m === "published" ? "published" : ""}">${escapeHtml(m)}</span>`).join("")}
          </div>
        `;

        if (href) {
          return `
            <a class="item" href="${escapeHtml(href)}" style="display:block; color:inherit; text-decoration:none;">
              ${inner}
            </a>
          `;
        }

        return `
          <article class="item">
            ${inner}
          </article>
        `;
      }

      async function loadDashboard() {
        try {
          const response = await fetch("/api/admin/dashboard");
          const data = await response.json();

          if (!response.ok || data.ok === false) {
            throw new Error(data.error || "Dashboard API failed.");
          }

          const counts = data.counts || {};
          setText("postsTotal", counts.posts?.total);
          setText("postsDraft", counts.posts?.draft);
          setText("postsPublished", counts.posts?.published);
          setText("productsTotal", counts.products?.total);
          setText("productsDraft", counts.products?.draft);
          setText("productsPublished", counts.products?.published);
          setText("mediaTotal", counts.media?.total);
          setText("pseoTotal", counts.pseo?.total);
          setText("pseoDraft", counts.pseo?.draft);
          setText("pseoPublished", counts.pseo?.published);

          const recent = data.recent || {};

          els.recentPosts.innerHTML = (recent.posts || []).length
            ? recent.posts.map((post) =>
                item(post.title || "Untitled post", [post.status || "draft", post.slug || "", post.created_at || ""], `/admin/posts?edit=${encodeURIComponent(post.id)}`)
              ).join("")
            : '<div class="empty">No posts yet.</div>';

          els.recentProducts.innerHTML = (recent.products || []).length
            ? recent.products.map((product) =>
                item(product.name || "Untitled product", [product.status || "draft", product.slug || "", `${product.price || ""} ${product.currency || ""}`.trim()], `/admin/products?edit=${encodeURIComponent(product.id)}`)
              ).join("")
            : '<div class="empty">No products yet.</div>';

          els.recentMedia.innerHTML = (recent.media || []).length
            ? recent.media.map((media) =>
                item(media.filename || "Untitled media", [media.mime_type || "", media.created_at || ""], "/admin/media")
              ).join("")
            : '<div class="empty">No media yet.</div>';

          els.recentPseo.innerHTML = (recent.pseo || []).length
            ? recent.pseo.map((page) =>
                item(page.title || "Untitled pSEO page", [page.status || "draft", page.pattern || "", page.slug || ""], `/admin/pseo?edit=${encodeURIComponent(page.id)}`)
              ).join("")
            : '<div class="empty">No pSEO pages yet.</div>';
        } catch (error) {
          els.recentPosts.innerHTML = `<div class="empty">${escapeHtml(error.message)}</div>`;
          els.recentProducts.innerHTML = `<div class="empty">${escapeHtml(error.message)}</div>`;
          els.recentMedia.innerHTML = `<div class="empty">${escapeHtml(error.message)}</div>`;
          els.recentPseo.innerHTML = `<div class="empty">${escapeHtml(error.message)}</div>`;
        }
      }

      els.refreshBtn.addEventListener("click", loadDashboard);
      loadDashboard();
    </script>
  </body>
</html>
