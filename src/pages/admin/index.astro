---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard | OwnitApps Admin</title>
    <style>
      :root {
        --sidebar-bg: #2B2B2B;
        --sidebar-text: #E8DDD0;
        --sidebar-muted: #9A8F82;
        --sidebar-border: #3A3A3A;
        --main-bg: #F5F0E8;
        --card: #FFFFFF;
        --surface-2: #F0EBE0;
        --border-light: rgba(0,0,0,0.07);
        --border-medium: rgba(0,0,0,0.12);
        --gold: #C9A84C;
        --gold-hover: #B8932E;
        --green: #2E8B5A;
        --red: #C0392B;
        --blue: #2471A3;
        --text-primary: #2B2B2B;
        --text-secondary: #6B6258;
        --text-muted: #9A8F82;
        --r: 10px;
        --rs: 6px;
        --font-heading: "Syne", "Inter", "Segoe UI", system-ui, sans-serif;
        --font-body: "DM Sans", "Inter", "Segoe UI", system-ui, sans-serif;
        --font-mono: "DM Mono", "SFMono-Regular", Consolas, monospace;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        background: var(--main-bg);
        color: var(--text-primary);
        font-family: var(--font-body);
      }

      .shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 240px 1fr;
      }

      aside {
        background: var(--sidebar-bg);
        color: var(--sidebar-text);
        padding: 24px 18px;
        border-right: 1px solid var(--sidebar-border);
      }

      .brand {
        font-family: var(--font-heading);
        font-weight: 800;
        letter-spacing: -0.03em;
        font-size: 22px;
        margin-bottom: 6px;
      }

      aside .muted {
        color: var(--sidebar-muted);
        font-size: 12px;
        line-height: 1.5;
      }

      nav {
        display: grid;
        gap: 8px;
        margin-top: 28px;
      }

      nav a {
        color: var(--sidebar-text);
        text-decoration: none;
        padding: 10px 12px;
        border-radius: var(--rs);
        font-size: 14px;
      }

      nav a.active,
      nav a:hover {
        background: rgba(201,168,76,.14);
        color: #fff;
      }

      main {
        padding: 32px;
        max-width: 1500px;
        width: 100%;
      }

      .topbar {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 24px;
      }

      h1 {
        font-family: var(--font-heading);
        font-weight: 800;
        letter-spacing: -0.04em;
        font-size: clamp(34px, 4vw, 56px);
        margin: 0 0 8px;
      }

      .subtitle {
        color: var(--text-secondary);
        max-width: 820px;
        line-height: 1.6;
        margin: 0;
      }

      .kpis {
        display: grid;
        grid-template-columns: repeat(5, minmax(130px, 1fr));
        gap: 14px;
        margin-bottom: 20px;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--border-light);
        border-radius: var(--r);
        box-shadow: 0 18px 50px rgba(43,43,43,.06);
      }

      .kpi {
        padding: 18px;
      }

      .kpi-label {
        color: var(--text-secondary);
        font-family: var(--font-mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: 8px;
      }

      .kpi-value {
        font-family: var(--font-heading);
        font-size: 34px;
        font-weight: 900;
        letter-spacing: -0.05em;
      }

      .kpi-note {
        color: var(--text-muted);
        font-size: 12px;
        margin-top: 8px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 20px;
      }

      .card-body {
        padding: 18px;
      }

      h2 {
        font-family: var(--font-heading);
        letter-spacing: -0.03em;
        margin: 0 0 12px;
        font-size: 22px;
      }

      .list {
        display: grid;
        gap: 10px;
      }

      .item {
        border: 1px solid var(--border-light);
        background: #fff;
        border-radius: var(--r);
        padding: 12px;
      }

      .item-title {
        font-weight: 800;
        margin-bottom: 5px;
      }

      .item-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        color: var(--text-muted);
        font-family: var(--font-mono);
        font-size: 12px;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        padding: 3px 8px;
        border-radius: 999px;
        background: var(--surface-2);
        border: 1px solid var(--border-light);
      }

      .badge.published {
        color: var(--green);
        background: rgba(46,139,90,.1);
        border-color: rgba(46,139,90,.2);
      }

      .actions {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin-top: 20px;
      }

      .action {
        display: block;
        text-decoration: none;
        color: var(--text-primary);
        padding: 18px;
        border-radius: var(--r);
        background: var(--card);
        border: 1px solid var(--border-light);
        box-shadow: 0 18px 50px rgba(43,43,43,.04);
      }

      .action strong {
        display: block;
        font-family: var(--font-heading);
        margin-bottom: 6px;
      }

      .action span {
        display: block;
        color: var(--text-muted);
        font-size: 13px;
        line-height: 1.45;
      }

      button {
        appearance: none;
        border: 0;
        border-radius: var(--rs);
        padding: 10px 14px;
        min-height: 42px;
        cursor: pointer;
        font-weight: 700;
      }

      .secondary {
        background: var(--surface-2);
        color: var(--text-primary);
        border: 1px solid var(--border-medium);
      }

      .empty {
        color: var(--text-muted);
        padding: 18px;
        border: 1px dashed var(--border-medium);
        border-radius: var(--r);
      }

      @media (max-width: 1200px) {
        .kpis {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .grid,
        .actions {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 800px) {
        .shell {
          grid-template-columns: 1fr;
        }

        nav {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        main {
          padding: 20px;
          padding-bottom: 100px;
        }

        .topbar {
          display: block;
        }

        .kpis,
        .grid,
        .actions {
          grid-template-columns: 1fr;
        }
      }
    
      /* Premium recent-card polish */
      .item {
        transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
      }

      a.item:hover {
        transform: translateY(-2px);
        box-shadow: 0 18px 44px rgba(43,43,43,.10);
        border-color: rgba(201,168,76,.35);
      }

      .item-title {
        line-height: 1.25;
        letter-spacing: -0.02em;
      }

      .item-meta {
        display: flex !important;
        gap: 7px !important;
        flex-wrap: wrap !important;
        align-items: center;
        margin-top: 8px;
      }

      .item-meta span,
      .item-meta .badge {
        display: inline-flex !important;
        align-items: center;
        width: auto;
        max-width: 100%;
        padding: 4px 8px;
        border-radius: 999px;
        background: var(--surface-2);
        border: 1px solid var(--border-light);
        color: var(--text-muted);
        font-family: var(--font-mono);
        font-size: 11px;
        line-height: 1.1;
        white-space: nowrap;
      }

      .item-meta .badge.published,
      .item-meta span.published {
        color: var(--green);
        background: rgba(46,139,90,.10);
        border-color: rgba(46,139,90,.22);
      }

      .item-meta span:first-child {
        font-weight: 800;
      }
    </style>
  </head>

  <body>
    <div class="shell">
      <aside>
        <div class="brand">OwnitApps</div>
        <p class="muted">Live admin command center powered by D1, R2, and Cloudflare Access.</p>

        <nav>
          <a class="active" href="/admin/">Dashboard</a>
          <a href="/admin/posts">Posts</a>
          <a href="/admin/products">Products</a>
          <a href="/admin/media">Media</a>
          <a href="/admin/pseo">pSEO</a>
          <a href="/admin/seo">SEO</a>
          <a href="/admin/settings">Settings</a>
          <a href="/">View Site</a>
        </nav>
      </aside>

      <main>
        <div class="topbar">
          <div>
            <h1>Dashboard</h1>
            <p class="subtitle">
              Real-time OwnitApps admin overview. Counts and recent activity are loaded from Cloudflare D1.
            </p>
          </div>
          <button class="secondary" id="refreshBtn">Refresh</button>
        </div>

        <section class="kpis">
          <div class="card kpi">
            <div class="kpi-label">Total Posts</div>
            <div class="kpi-value" id="postsTotal">ط·آ£ط¢آ¢ط£آ¢أ¢â‚¬ع‘ط¢آ¬ط£آ¢أ¢â€ڑآ¬أ¢â‚¬إ’</div>
            <div class="kpi-note">All saved posts</div>
          </div>
          <div class="card kpi">
            <div class="kpi-label">Draft Posts</div>
            <div class="kpi-value" id="postsDraft">ط·آ£ط¢آ¢ط£آ¢أ¢â‚¬ع‘ط¢آ¬ط£آ¢أ¢â€ڑآ¬أ¢â‚¬إ’</div>
            <div class="kpi-note">Not published</div>
          </div>
          <div class="card kpi">
            <div class="kpi-label">Published Posts</div>
            <div class="kpi-value" id="postsPublished">ط·آ£ط¢آ¢ط£آ¢أ¢â‚¬ع‘ط¢آ¬ط£آ¢أ¢â€ڑآ¬أ¢â‚¬إ’</div>
            <div class="kpi-note">Live-ready content</div>
          </div>
          <div class="card kpi">
            <div class="kpi-label">Products</div>
            <div class="kpi-value" id="productsTotal">ط·آ£ط¢آ¢ط£آ¢أ¢â‚¬ع‘ط¢آ¬ط£آ¢أ¢â€ڑآ¬أ¢â‚¬إ’</div>
            <div class="kpi-note">All product records</div>
          </div>
          <div class="card kpi">
            <div class="kpi-label">Product Drafts</div>
            <div class="kpi-value" id="productsDraft">ط·آ£ط¢آ¢ط£آ¢أ¢â‚¬ع‘ط¢آ¬ط£آ¢أ¢â€ڑآ¬أ¢â‚¬إ’</div>
            <div class="kpi-note">Needs review</div>
          </div>
          <div class="card kpi">
            <div class="kpi-label">Published Products</div>
            <div class="kpi-value" id="productsPublished">ط·آ£ط¢آ¢ط£آ¢أ¢â‚¬ع‘ط¢آ¬ط£آ¢أ¢â€ڑآ¬أ¢â‚¬إ’</div>
            <div class="kpi-note">Ready to sell</div>
          </div>
          <div class="card kpi">
            <div class="kpi-label">Media Files</div>
            <div class="kpi-value" id="mediaTotal">ط·آ£ط¢آ¢ط£آ¢أ¢â‚¬ع‘ط¢آ¬ط£آ¢أ¢â€ڑآ¬أ¢â‚¬إ’</div>
            <div class="kpi-note">Stored in R2</div>
          </div>
        
          <div class="card kpi">
            <div class="kpi-label">pSEO Pages</div>
