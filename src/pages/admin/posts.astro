  <body>
    <div class="shell">
      <aside>
        <div class="brand">OwnitApps</div>
        <p class="muted">Private admin dashboard. Protected by Cloudflare Access.</p>

        <nav>
          <a href="/admin/">Dashboard</a>
          <a class="active" href="/admin/posts">Posts</a>
          <a href="/admin/products">Products</a>
          <a href="/admin/media">Media</a>
          <a href="/admin/pseo">pSEO</a>
          <a href="/admin/seo">SEO</a>
          <a href="/admin/settings">Settings</a>
          <a href="/">View Site</a>
        </nav>
      </aside>

      <main>
        <div class="topbar">
          <div>
            <h1>Posts Manager</h1>
            <p class="subtitle">
              Create, edit, publish, and delete OwnitApps blog and pSEO posts. Data is saved in Cloudflare D1 through the protected admin API.
            </p>
          </div>
          <button class="secondary" id="refreshBtn">Refresh</button>
        </div>

        <div class="grid">
          <section class="card">
            <div class="card-head">
              <h2 id="formTitle">Create Post</h2>
              <p class="small" id="editingLabel">New draft</p>
            </div>

            <div class="card-body">
              <input type="hidden" id="postId" />

              <label for="title">Title</label>
              <input id="title" placeholder="Example: Why Offline-First Apps Are Coming Back" />

              <label for="slug">Slug</label>
              <input id="slug" placeholder="why-offline-first-apps-are-coming-back" />

              <div class="row">
                <div>
                  <label for="status">Status</label>
                  <select id="status">
                    <option value="draft">Draft</option>
                    <option value="published">Published</option>
                  </select>
                </div>
                <div>
                  <label for="category">Category</label>
                  <input id="category" placeholder="Insights" />
                </div>
              </div>

              <label for="excerpt">Excerpt</label>
              <textarea id="excerpt" placeholder="Short summary for cards and previews."></textarea>

              <label for="seoTitle">SEO Title</label>
              <input id="seoTitle" maxlength="60" placeholder="Under 60 characters" />

              <label for="seoDescription">Meta Description</label>
              <textarea id="seoDescription" maxlength="160" placeholder="Under 160 characters"></textarea>

              <label for="ogImage">Featured / OG Image Public URL</label>
              <input id="ogImage" placeholder="https://ownitapps.com/media/uploads/..." />

              <label for="tags">Tags</label>
              <input id="tags" placeholder="offline-first, privacy, no subscription" />

              <label for="content">Markdown Content</label>
              <textarea id="content" class="content-area" placeholder="# Start writing here..."></textarea>

              <div class="actions">
                <button class="primary" id="saveBtn">Save Post</button>
                <button class="secondary" id="newBtn">New</button>
                <button class="danger" id="deleteBtn" disabled>Delete</button>
                <button class="secondary" id="previewBtn" disabled>Preview</button>
                <button class="secondary" id="liveBtn" disabled>Live</button>
              </div>
            </div>
          </section>

          <section class="card">
            <div class="card-body">
              <div class="toolbar">
                <div>
                  <h2>All Posts</h2>
                  <p class="small"><span id="count">0</span> post(s) in D1</p>
                </div>
                <input class="search" id="search" placeholder="Search posts..." />
              </div>

              <div id="posts" class="post-list">
                <div class="empty">Loading posts...</div>
              </div>
            </div>
          </section>
        </div>
      </main>
    </div>

    <div class="toast" id="toast"></div>

    <script>
      const API = "/api/admin/posts";

      const els = {
        postId: document.getElementById("postId"),
        title: document.getElementById("title"),
        slug: document.getElementById("slug"),
        status: document.getElementById("status"),
        category: document.getElementById("category"),
        excerpt: document.getElementById("excerpt"),
        seoTitle: document.getElementById("seoTitle"),
        seoDescription: document.getElementById("seoDescription"),
        ogImage: document.getElementById("ogImage"),
        tags: document.getElementById("tags"),
        content: document.getElementById("content"),
        saveBtn: document.getElementById("saveBtn"),
        newBtn: document.getElementById("newBtn"),
        deleteBtn: document.getElementById("deleteBtn"),
        previewBtn: document.getElementById("previewBtn"),
        liveBtn: document.getElementById("liveBtn"),
        refreshBtn: document.getElementById("refreshBtn"),
        posts: document.getElementById("posts"),
        count: document.getElementById("count"),
        search: document.getElementById("search"),
        formTitle: document.getElementById("formTitle"),
        editingLabel: document.getElementById("editingLabel"),
        toast: document.getElementById("toast"),
      };

      let allPosts = [];

      function toast(message) {
        els.toast.textContent = message;
        els.toast.classList.add("show");
        setTimeout(() => els.toast.classList.remove("show"), 2600);
      }

      function slugify(value) {
        return String(value || "")
          .trim()
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "")
          .slice(0, 120);
      }

      function parseCsv(value) {
        return String(value || "")
          .split(",")
          .map((x) => x.trim())
          .filter(Boolean);
      }

      function resetForm() {
        els.postId.value = "";
        els.title.value = "";
        els.slug.value = "";
        els.status.value = "draft";
        els.category.value = "";
        els.excerpt.value = "";
        els.seoTitle.value = "";
        els.seoDescription.value = "";
        els.ogImage.value = "";
        els.tags.value = "";
        els.content.value = "";
        els.deleteBtn.disabled = true;
        els.previewBtn.disabled = true;
        els.liveBtn.disabled = true;
        els.formTitle.textContent = "Create Post";
        els.editingLabel.textContent = "New draft";
      }

      function fillForm(post) {
        els.postId.value = post.id || "";
        els.title.value = post.title || "";
        els.slug.value = post.slug || "";
        els.status.value = post.status || "draft";
        els.category.value = post.category || "";
        els.excerpt.value = post.excerpt || "";
        els.seoTitle.value = post.seo_title || "";
        els.seoDescription.value = post.seo_description || "";
        els.ogImage.value = post.og_image || "";
        els.tags.value = safeJsonArray(post.tags_json).join(", ");
        els.content.value = post.content_markdown || "";
        els.deleteBtn.disabled = false;
        els.previewBtn.disabled = false;
        els.liveBtn.disabled = false;
        els.formTitle.textContent = "Edit Post";
        els.editingLabel.textContent = post.slug ? "/" + post.slug : post.id;
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      function safeJsonArray(value) {
        if (!value) return [];
        try {
          const parsed = JSON.parse(value);
          return Array.isArray(parsed) ? parsed : [];
        } catch {
          return [];
        }
      }

      function getPayload() {
        return {
          title: els.title.value.trim(),
          slug: slugify(els.slug.value || els.title.value),
          status: els.status.value,
          category: els.category.value.trim() || null,
          excerpt: els.excerpt.value.trim() || null,
          seo_title: els.seoTitle.value.trim() || null,
          seo_description: els.seoDescription.value.trim() || null,
          og_image: els.ogImage.value.trim() || null,
          tags: parseCsv(els.tags.value),
          content_markdown: els.content.value.trim(),
        };
      }

      async function api(path, options = {}) {
        const response = await fetch(path, {
          ...options,
          headers: {
            "content-type": "application/json",
            ...(options.headers || {}),
          },
        });

        const data = await response.json().catch(() => ({}));
        if (!response.ok || data.ok === false) {
          throw new Error(data.error || "Request failed");
        }

        return data;
      }

      async function loadPosts() {
        els.posts.innerHTML = '<div class="empty">Loading posts...</div>';

        try {
          const data = await api(API);
          allPosts = data.posts || [];
          renderPosts();
        } catch (error) {
          els.posts.innerHTML = `<div class="empty">Could not load posts: ${escapeHtml(error.message)}</div>`;
          toast(error.message);
        }
      }

      async function loadFullPost(id) {
        try {
          const data = await api(API + "/" + encodeURIComponent(id));
          fillForm(data.post);
        } catch (error) {
          toast(error.message);
        }
      }

      function renderPosts() {
        const query = els.search.value.trim().toLowerCase();
        const filtered = allPosts.filter((post) => {
          const text = [
            post.title,
            post.slug,
            post.status,
            post.category,
            post.excerpt,
          ].join(" ").toLowerCase();
          return text.includes(query);
        });

        els.count.textContent = String(filtered.length);

        if (!filtered.length) {
          els.posts.innerHTML = '<div class="empty">No posts found. Create your first draft.</div>';
          return;
        }

        els.posts.innerHTML = filtered.map((post) => `
          <article class="post-item">
            <div>
              <div class="post-title">${escapeHtml(post.title || "Untitled")}</div>
              <div class="post-meta">
                <span class="badge ${post.status === "published" ? "published" : ""}">${escapeHtml(post.status || "draft")}</span>
                <span>${escapeHtml(post.slug || "")}</span>
                <span>${escapeHtml(post.category || "No category")}</span>
              </div>
            </div>
            <button class="info" data-edit="${escapeHtml(post.id)}">Edit</button>
          </article>
        `).join("");

        document.querySelectorAll("[data-edit]").forEach((btn) => {
          btn.addEventListener("click", () => loadFullPost(btn.dataset.edit));
        });
      }

      function escapeHtml(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      }

      async function savePost() {
        const payload = getPayload();

        if (!payload.title) {
          toast("Title is required.");
          return;
        }

        if (!payload.content_markdown) {
          toast("Markdown content is required.");
          return;
        }

        try {
          const id = els.postId.value;
          const data = id
            ? await api(API + "/" + encodeURIComponent(id), {
                method: "PUT",
                body: JSON.stringify(payload),
              })
            : await api(API, {
                method: "POST",
                body: JSON.stringify(payload),
              });

          toast(id ? "Post updated." : "Post created.");
          fillForm(data.post);
          await async function initPostsPage() {
        await loadPosts();

        const params = new URLSearchParams(window.location.search);
        const editId = params.get("edit");

        if (editId) {
          await loadFullPost(editId);
        }
      }

      initPostsPage();
        } catch (error) {
          toast(error.message);
        }
      }

      function previewPost() {
        const slug = slugify(els.slug.value || els.title.value);
        if (!slug) {
          toast("Save the post with a valid slug first.");
          return;
        }

        window.open(`/preview/post/${encodeURIComponent(slug)}`, "_blank", "noopener");
      }

      function openLivePost() {
        const slug = slugify(els.slug.value || els.title.value);
        if (!slug) {
          toast("Save the post with a valid slug first.");
          return;
        }

        window.open(`/blog-live/${encodeURIComponent(slug)}`, "_blank", "noopener");
      }

      async function deletePost() {
        const id = els.postId.value;
        if (!id) return;

        const ok = confirm("Delete this post permanently?");
        if (!ok) return;

        try {
          await api(API + "/" + encodeURIComponent(id), { method: "DELETE" });
          toast("Post deleted.");
          resetForm();
          await async function initPostsPage() {
        await loadPosts();

        const params = new URLSearchParams(window.location.search);
        const editId = params.get("edit");

        if (editId) {
          await loadFullPost(editId);
        }
      }

      initPostsPage();
        } catch (error) {
          toast(error.message);
        }
      }

      els.title.addEventListener("input", () => {
        if (!els.postId.value && !els.slug.value) {
          els.slug.value = slugify(els.title.value);
        }
      });

      els.search.addEventListener("input", renderPosts);
      els.saveBtn.addEventListener("click", savePost);
      els.newBtn.addEventListener("click", resetForm);
      els.deleteBtn.addEventListener("click", deletePost);
      els.previewBtn.addEventListener("click", previewPost);
      els.liveBtn.addEventListener("click", openLivePost);
      els.refreshBtn.addEventListener("click", loadPosts);

      async function initPostsPage() {
        await loadPosts();

        const params = new URLSearchParams(window.location.search);
        const editId = params.get("edit");

        if (editId) {
          await loadFullPost(editId);
        }
      }

      initPostsPage();
    </script>
  </body>
</html>
