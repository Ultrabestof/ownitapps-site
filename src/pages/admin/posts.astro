<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Posts Manager | OwnitApps Admin</title>
    <style>
      :root {
        --sidebar-bg: #2B2B2B;
        --sidebar-text: #E8DDD0;
        --sidebar-muted: #9A8F82;
        --sidebar-border: #3A3A3A;
        --main-bg: #F5F0E8;
        --card: #FFFFFF;
        --surface-2: #F0EBE0;
        --border-light: rgba(0,0,0,0.07);
        --border-medium: rgba(0,0,0,0.12);
        --gold: #C9A84C;
        --gold-hover: #B8932E;
        --green: #2E8B5A;
        --red: #C0392B;
        --blue: #2471A3;
        --text-primary: #2B2B2B;
        --text-secondary: #6B6258;
        --text-muted: #9A8F82;
        --r: 10px;
        --rs: 6px;
        --font-heading: "Syne", "Inter", "Segoe UI", system-ui, sans-serif;
        --font-body: "DM Sans", "Inter", "Segoe UI", system-ui, sans-serif;
        --font-mono: "DM Mono", "SFMono-Regular", Consolas, monospace;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        background: var(--main-bg);
        color: var(--text-primary);
        font-family: var(--font-body);
      }

      .shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 240px 1fr;
      }

      aside {
        background: var(--sidebar-bg);
        color: var(--sidebar-text);
        padding: 24px 18px;
        border-right: 1px solid var(--sidebar-border);
      }

      .brand {
        font-family: var(--font-heading);
        font-weight: 800;
        letter-spacing: -0.03em;
        font-size: 22px;
        margin-bottom: 6px;
      }

      .muted {
        color: var(--text-muted);
      }

      aside .muted {
        color: var(--sidebar-muted);
        font-size: 12px;
        line-height: 1.5;
      }

      nav {
        display: grid;
        gap: 8px;
        margin-top: 28px;
      }

      nav a {
        color: var(--sidebar-text);
        text-decoration: none;
        padding: 10px 12px;
        border-radius: var(--rs);
        font-size: 14px;
      }

      nav a.active,
      nav a:hover {
        background: rgba(201,168,76,.14);
        color: #fff;
      }

      main {
        padding: 32px;
        max-width: 1500px;
        width: 100%;
      }

      .topbar {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 24px;
      }

      h1 {
        font-family: var(--font-heading);
        font-weight: 800;
        letter-spacing: -0.04em;
        font-size: clamp(32px, 4vw, 52px);
        margin: 0 0 8px;
      }

      .subtitle {
        color: var(--text-secondary);
        max-width: 720px;
        line-height: 1.6;
        margin: 0;
      }

      .grid {
        display: grid;
        grid-template-columns: minmax(320px, 430px) 1fr;
        gap: 20px;
        align-items: start;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--border-light);
        border-radius: var(--r);
        box-shadow: 0 18px 50px rgba(43,43,43,.06);
      }

      .card-head {
        padding: 18px 18px 0;
      }

      .card-body {
        padding: 18px;
      }

      h2 {
        font-family: var(--font-heading);
        letter-spacing: -0.03em;
        margin: 0 0 10px;
        font-size: 22px;
      }

      label {
        display: block;
        font-size: 12px;
        font-family: var(--font-mono);
        color: var(--text-secondary);
        margin: 13px 0 6px;
      }

      input,
      textarea,
      select {
        width: 100%;
        border: 1px solid var(--border-medium);
        border-radius: var(--rs);
        padding: 10px 12px;
        background: #fff;
        color: var(--text-primary);
        font: inherit;
        min-height: 42px;
      }

      textarea {
        min-height: 130px;
        resize: vertical;
        line-height: 1.55;
      }

      .content-area {
        min-height: 260px;
        font-family: var(--font-mono);
        font-size: 13px;
      }

      .row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 18px;
      }

      button,
      .button {
        appearance: none;
        border: 0;
        border-radius: var(--rs);
        padding: 10px 14px;
        min-height: 42px;
        cursor: pointer;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
      }

      .primary {
        background: var(--gold);
        color: #1f1f1f;
      }

      .primary:hover {
        background: var(--gold-hover);
      }

      .secondary {
        background: var(--surface-2);
        color: var(--text-primary);
        border: 1px solid var(--border-medium);
      }

      .danger {
        background: rgba(192,57,43,.1);
        color: var(--red);
        border: 1px solid rgba(192,57,43,.22);
      }

      .info {
        background: rgba(36,113,163,.1);
        color: var(--blue);
        border: 1px solid rgba(36,113,163,.2);
      }

      .post-list {
        display: grid;
        gap: 10px;
      }

      .post-item {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 12px;
        padding: 14px;
        border: 1px solid var(--border-light);
        border-radius: var(--r);
        background: #fff;
      }

      .post-title {
        font-weight: 800;
        margin-bottom: 4px;
      }

      .post-meta {
        font-family: var(--font-mono);
        color: var(--text-muted);
        font-size: 12px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        padding: 3px 8px;
        border-radius: 99px;
        font-family: var(--font-mono);
        font-size: 11px;
        border: 1px solid var(--border-light);
        background: var(--surface-2);
        color: var(--text-secondary);
      }

      .badge.published {
        color: var(--green);
        background: rgba(46,139,90,.1);
        border-color: rgba(46,139,90,.2);
      }

      .toolbar {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
      }

      .search {
        max-width: 340px;
      }

      .toast {
        position: fixed;
        right: 18px;
        bottom: 18px;
        background: var(--sidebar-bg);
        color: var(--sidebar-text);
        padding: 12px 14px;
        border-radius: var(--r);
        box-shadow: 0 18px 60px rgba(0,0,0,.22);
        display: none;
        z-index: 999;
        max-width: 360px;
      }

      .toast.show {
        display: block;
      }

      .small {
        font-size: 12px;
        color: var(--text-muted);
      }

      .empty {
        padding: 30px;
        text-align: center;
        color: var(--text-muted);
        border: 1px dashed var(--border-medium);
        border-radius: var(--r);
        background: rgba(255,255,255,.6);
      }


      /* Admin list polish */
      .post-list {
        display: grid;
        gap: 12px;
      }

      .post-item {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: start;
        gap: 14px;
        padding: 16px;
        border: 1px solid var(--border-light);
        border-radius: var(--r);
        background: #fff;
        box-shadow: 0 10px 30px rgba(43,43,43,.04);
      }

      .post-title {
        font-family: var(--font-heading);
        font-weight: 850;
        font-size: 17px;
        line-height: 1.25;
        margin-bottom: 10px;
        max-width: 780px;
      }

      .post-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        align-items: center;
        color: var(--text-muted);
        font-family: var(--font-mono);
        font-size: 12px;
      }

      .post-meta > span:not(.badge) {
        display: inline-flex;
        max-width: 260px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        padding: 3px 8px;
        border-radius: 999px;
        background: var(--surface-2);
        border: 1px solid var(--border-light);
      }

      @media (max-width: 980px) {
        .shell {
          grid-template-columns: 1fr;
        }

        aside {
          position: static;
        }

        nav {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        main {
          padding: 20px;
          padding-bottom: 100px;
        }

        .grid,
        .row {
          grid-template-columns: 1fr;
        }

        .topbar {
          display: block;
        }
      }
    
      /* FORCED_ADMIN_LIST_POLISH */
      .post-list,
      .product-list,
      .media-list,
      #pages {
        display: grid !important;
        gap: 12px !important;
      }

      .post-item,
      .product-item,
      .media-item,
      #pages .item {
        display: grid !important;
        grid-template-columns: minmax(0, 1fr) auto !important;
        align-items: start !important;
        gap: 14px !important;
        padding: 16px !important;
        border: 1px solid var(--border-light, rgba(0,0,0,.08)) !important;
        border-radius: var(--r, 10px) !important;
        background: #fff !important;
        box-shadow: 0 10px 30px rgba(43,43,43,.045) !important;
        margin: 0 0 12px !important;
      }

      .media-item {
        grid-template-columns: minmax(0, 1fr) !important;
      }

      .post-title,
      .product-title,
      .media-title,
      #pages .title {
        display: block !important;
        font-family: var(--font-heading, system-ui) !important;
        font-weight: 850 !important;
        font-size: 17px !important;
        line-height: 1.25 !important;
        margin: 0 0 10px !important;
        max-width: 760px !important;
        color: var(--text-primary, #2B2B2B) !important;
      }

      .post-meta,
      .product-meta,
      .media-meta,
      #pages .meta {
        display: flex !important;
        flex-wrap: wrap !important;
        align-items: center !important;
        gap: 7px !important;
        color: var(--text-muted, #9A8F82) !important;
        font-family: var(--font-mono, monospace) !important;
        font-size: 12px !important;
        line-height: 1.4 !important;
      }

      .post-meta > span,
      .product-meta > span,
      #pages .meta > span,
      .media-meta > span {
        display: inline-flex !important;
        align-items: center !important;
        max-width: 280px !important;
        min-width: 0 !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        white-space: nowrap !important;
        padding: 4px 8px !important;
        border-radius: 999px !important;
        background: var(--surface-2, #F0EBE0) !important;
        border: 1px solid var(--border-light, rgba(0,0,0,.08)) !important;
      }

      .media-meta > span {
        max-width: 100% !important;
        white-space: normal !important;
        overflow-wrap: anywhere !important;
      }

      .badge,
      #pages .badge,
      .post-meta .badge,
      .product-meta .badge {
        display: inline-flex !important;
        align-items: center !important;
        padding: 4px 8px !important;
        border-radius: 999px !important;
        background: var(--surface-2, #F0EBE0) !important;
        border: 1px solid var(--border-light, rgba(0,0,0,.08)) !important;
        color: var(--text-muted, #9A8F82) !important;
      }

      .badge.published,
      #pages .badge.published,
      .post-meta .badge.published,
      .product-meta .badge.published {
        color: var(--green, #2E8B5A) !important;
        background: rgba(46,139,90,.10) !important;
        border-color: rgba(46,139,90,.22) !important;
      }

      .post-item button,
      .product-item button,
      #pages .item button,
      .media-item button {
        justify-self: end !important;
        min-height: 34px !important;
        padding: 7px 11px !important;
        border-radius: var(--rs, 6px) !important;
      }

      .media-meta a {
        color: #806515 !important;
        font-weight: 800 !important;
        overflow-wrap: anywhere !important;
      }

      @media (max-width: 900px) {
        .post-item,
        .product-item,
        #pages .item {
          grid-template-columns: 1fr !important;
        }

        .post-item button,
        .product-item button,
        #pages .item button {
          justify-self: start !important;
        }
      }
      /* /FORCED_ADMIN_LIST_POLISH */
    
      /* ADMIN_POLISH_V2 */
      .list,
      .post-list,
      .product-list,
      .media-list,
      #pages {
