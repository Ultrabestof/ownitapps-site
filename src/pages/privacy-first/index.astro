---
import PublicLayout from '@layouts/PublicLayout.astro';
import { buildSEO } from '@lib/seo';
import { SITE } from '@data/site';

const seo = buildSEO({
  title: 'Privacy-First Tools Hub',
  description: 'Programmatic SEO hub for privacy-first personal tools, local data dashboards, and account-light workflows.',
  canonical: `${SITE.url}${'/privacy-first'}`,
});
---

<PublicLayout seo={seo} schema={null}>
  <section class="container py-16">
    <div class="max-w-3xl">
      <span class="badge badge-gold mb-4">pSEO Hub</span>
      <h1 class="mb-4">Privacy-First Tools</h1>
      <p class="text-lg leading-relaxed text-[var(--text-secondary)] mb-8">Privacy-first pages for people who want practical tools without unnecessary tracking or cloud lock-in.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-4 mt-8">
      <a href="/privacy-first/privacy-first-budget-planner" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Budget Planner</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Privacy-first budget planner.</p>
      </a>
      <a href="/privacy-first-tools" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Privacy-First Source</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Learn the concept.</p>
      </a>
      <a href="/apps" class="card p-5 hover:-translate-y-0.5 transition-transform">
        <h2 class="text-lg mb-2">Apps</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">Browse tools.</p>
      </a>
    </div>
  </section>
</PublicLayout>
